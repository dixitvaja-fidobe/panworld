<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="views_import_sale_rma_return_wizard" model="ir.ui.view">
        <field name="name">import.sale.rma.return.wizard.form</field>
        <field name="model">import.sale.rma.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Sale Return">
                <group>
                    <group>
                        <field name="file" filename="name" />
                    </group>
                    <group>
                        <field
                            name="sample_file"
                            filename="file_name"
                            readonly="1"
                            invisible="sample_file == False"
                        />
                        <field name="file_name" invisible="1" />
                        <button
                            string="Download Sample File"
                            name="download_sample_file"
                            class="oe_highlight"
                            type="object"
                        />
                    </group>
                </group>
                <footer>
                    <button
                        name="import_sale_return"
                        string="Import"
                        type="object"
                        class="oe_highlight"
                    />
                </footer>
            </form>
        </field>
    </record>
    <record id="actions_import_sale_rma_return_wizard" model="ir.actions.act_window">
        <field name="name">Import Sale Return</field>
        <field name="res_model">import.sale.rma.return.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem
        id="menu_import_sale_return_wizard"
        action="actions_import_sale_rma_return_wizard"
        parent="menu_main_rma"
    />
</odoo>
