<odoo>
    <!-- Inherited Stock Picking Form -->
    <record id="view_stock_order_form_inherit" model="ir.ui.view">
        <field name="name">view.stock.order.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group[2]" position="inside">
                <field name="valid_invoice_ids" invisible="1"/>
                <field name="rma_id" invisible="1"/>
                <field name="partner_bill_ids"
                       widget="many2many_tags"
                       domain="[('id', 'in', valid_invoice_ids)]"
                       invisible="rma_id == False"/>
            </xpath>
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="rma_done" readonly="1" force_save="1" />
                <field name="rma_id" invisible="1" />
            </xpath>
            <xpath
                expr="//button[@name='%(stock.act_stock_return_picking)d']"
                position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_company_form_inherit_scs_rma" model="ir.ui.view">
        <field name="name">view.company.form.inherit.scs.rma</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='lot_id']" position="attributes">
                <attribute name='column_invisible'>0</attribute>
            </xpath>
        </field>
    </record>
</odoo>
