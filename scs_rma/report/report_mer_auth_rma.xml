                                    </td>
                                    <td class="text-center">
                                        <span t-field="l.refund_qty" />
                                    </td>
                                    <td class="text-center">
                                        <span t-field="l.price_unit" />
                                    </td>
                                    <td class="text-right">
                                        <!-- <span
                                            t-esc="', '.join(map(lambda x: (x.description or x.name), l.tax_id))"
                                        /> -->
                                        <span t-esc="', '.join(map(lambda x: (str(int(x.amount)) + '%'), l.tax_id))"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-set="vat_amount" t-value="sum(t.amount or 0.0 for t in l.tax_id)"/>
                                        <t t-set="vat_amount" t-value="(l.refund_price or 0.0 * vat_amount or 0.0)/100"/>
                                        <span
                                            t-esc="vat_amount" t-options='{"widget": "float", "precision": 2}'
                                        />
                                    </td>
                                    <td class="text-right">
                                        <span
                                            t-field="l.refund_price"
