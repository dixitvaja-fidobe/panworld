<odoo>

    <record id="paperformat_rma" model="report.paperformat">
            <field name="name">Paper Format- RMA</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">34</field>
            <field name="margin_bottom">32</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">54</field>
            <field name="dpi">90</field>
        </record>

    <template id="report_rma_scs_document">
        <t t-call="web.external_layout">
            <div class="page">
                <h2 class="text-center">
                    <t t-if="doc.rma_type=='customer'">
                        <span>Sale Return </span>
                    </t>
                    <t t-if="doc.rma_type=='supplier'">
                        <span>Purchase Return </span>
                    </t>
                    <t t-if="doc.rma_type=='direct'">
                        <span>Puchase Direct Return </span>
                    </t>
                    <t t-if="doc.rma_type=='sale_direct'">
                        <span>Sale Direct Return </span>
                    </t>
                    <t t-if="doc.rma_type=='invoice'">
                        <span>Invoice Return </span>
                    </t>
                     <t t-if="doc.rma_type in ('picking','lot')">
                        <span>RMA </span>
                     </t>
                </h2>
                <!-- <h2 class="text-center">
                    <span t-if="doc.rma_type == 'customer'">Customer Credit Note</span>
                    <span t-if="doc.rma_type == 'sale_direct'">Direct Customer Credit Note</span>
                    <span t-if="doc.rma_type == 'supplier'">Vendor Credit Note</span>
                    <span t-if="doc.rma_type == 'direct'">Direct Vendor Credit Note</span>
                    <span t-if="doc.rma_type == 'invoice'">Invoice Return</span>
                    <t t-if="doc.rma_type in ('picking','lot')">
                        <span>RMA </span>
                    </t>
                    <span t-if="doc.name != '/'" t-field="doc.name"/>
                </h2> -->
                <div class="oe_structure" />
                <div class="row">
                    <div class="col-6">
                        <br />
                        <t t-if="doc.rma_type in ('customer','sale_direct')">
                            <div
                                t-field="doc.partner_id"
                                t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                            />
                        </t>
                        <t t-if="doc.rma_type in ('supplier','invoice','direct')">
                            <div
                                t-field="doc.supplier_id"
                                t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                            />
                        </t>
                        <t t-if="doc.rma_type=='picking'">
                            <div
                                t-field="doc.picking_partner_id"
                                t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                            />
                        </t>
                        <t t-if="doc.rma_type=='lot' and doc.lot_picking_id">
                            <div
                                t-esc="doc.lot_picking_id.partner_id"
                                t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                            />
                        </t>
                    </div>
                </div>
                <br />

                    <div class="text-left"  style="margin-left:500px;">
                        <strong>Vendor Credit Note # </strong>
                        <span t-field="doc.name" />
                        <br />
                        <t t-if="doc.rma_date">
                            <strong>Date : </strong>
                            <span t-field="doc.rma_date" />
                            <br />
                            <t t-if="doc.sale_order_id">
                                <strong>S/O : </strong>
                                <span t-field="doc.sale_order_id.name" />
                            </t>
                            <t t-if="doc.purchase_order_id">
