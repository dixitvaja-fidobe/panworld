<?xml version="1.0" encoding="utf-8"?>
<odoo>
	
    <record id="confirm_credit_limit_views" model="ir.ui.view">
        <field name="name">confirm.credit.limit.form</field>
        <field name="model">confirm.credit.limit</field>
        <field name="arch" type="xml">
            <form string="Warning">
                <h3><field name="name" readonly='1'/></h3>
                <footer>
                    <button name="action_done_with_warnig" string="Continue" type="object" class="oe_highlight"/>
                    <!-- <button string="Cancel" class="oe_link" special="cancel" /> -->
                </footer>
            </form>
        </field>
    </record>

    <record id="action_confirm_credit_limit" model="ir.actions.act_window">
        <field name="name">Warning</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">confirm.credit.limit</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
 </odoo>
 