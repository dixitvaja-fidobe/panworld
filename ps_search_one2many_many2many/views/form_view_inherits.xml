<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_form_view_inherit" model="ir.ui.view">
        <field name="name">purchase.forms.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="widget">search_section_and_note_one2many</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_form_view_inherit" model="ir.ui.view">
        <field name="name">sale.forms.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="widget">search_section_and_note_one2many</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_management_form_view_inherit" model="ir.ui.view">
        <field name="name">sale_management.forms.inherit</field>
        <field name="model">sale.order.template</field>
        <field name="inherit_id" ref="sale_management.sale_order_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_template_line_ids']" position="attributes">
                <attribute name="widget">search_section_and_note_one2many</attribute>
            </xpath>
        </field>
    </record>

    <record id="account_form_view_inherit" model="ir.ui.view">
        <field name="name">account.forms.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']" position="attributes">
                <attribute name="widget">search_section_and_note_one2many</attribute>
            </xpath>
        </field>
    </record>
</odoo>
