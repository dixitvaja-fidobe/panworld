<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="PsSearchOptionTemplate" t-inherit="web.X2ManyField"
       t-inherit-mode="primary" owl="1">
        <xpath expr="//*[@t-if='displayControlPanelButtons']" position="before">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <input type="text" class="o_section_search_value searchInput pl-2"
                           placeholder="Search...."
                           t-ref="search_keywords"
                           style="margin-bottom:11px;height:32px;"
                           t-on-keyup="onInputKeyUp"/>
                </div>
                <div class="o_row_count_display" style="margin-bottom:11px;">
                    <span style="background-color: white; border: 1px solid #ccc; border-radius: 5px; padding: 6px 12px; font-size: 14px; color: #333;">
                        Total Rows: <strong><t t-esc="rowCount.total"/></strong>
                    </span>
                </div>
            </div>
        </xpath>
    </t>
</templates>
