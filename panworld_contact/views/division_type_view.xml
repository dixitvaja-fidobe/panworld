<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_division_type_form" model="ir.ui.view">
            <field name="name">view.division.type.form</field>
            <field name="model">division.type</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" class="oe_inline"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="sale_tat"/>
                                <field name="purchase_tat"/>
                                <field name="shipping_tat"/>
                            </group>
                            <group>
                                <field name="wh_tat"/>
                                <field name="delivery_tat"/>
                                <field name="po_tat"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_division_type_tree" model="ir.ui.view">
            <field name="name">view.division.type.tree</field>
            <field name="model">division.type</field>
            <field name="arch" type="xml">
                <list string="Division List">
                    <field name="name"/>
                    <field name="sale_tat"/>
                    <field name="purchase_tat"/>
                    <field name="shipping_tat"/>
                    <field name="wh_tat"/>
                    <field name="delivery_tat"/>
                    <field name="po_tat"/>
                </list>
            </field>
        </record>

        <record id="action_division_type" model="ir.actions.act_window">
            <field name="name">Division Type</field>
            <field name="res_model">division.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="division_type_menu"
            parent="sale.sale_order_menu"
            action="action_division_type"
            sequence="90"/>
    </data>
</odoo>