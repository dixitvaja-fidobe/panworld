<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_presale" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.presale</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_presale_tracking"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-bullseye"
                    invisible="not presale_tracking_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Presale Tracker</span>
                    </div>
                </button>
            </xpath>
            <button name="button_cancel" position="before">
                <button name="action_request_approval" string="Request for Approval" type="object" class="oe_highlight" 
                        invisible="state not in ['draft', 'sent'] or purchase_order_type != 'bulk'" 
                        groups="purchase.group_purchase_user"/>
                <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                        invisible="not action_approve_allowed or state not in ['waiting_approval']"
                        groups="account.group_account_manager"/>
            </button>
            <xpath expr="//header/field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sent,purchase</attribute>
            </xpath>
            <field name="date_order" position="before">
<!--                <field name="sourcing_vendor_id" readonly="1" invisible="not sourcing_vendor_id"/>-->
                <field name="sourcing_vendor_id"/>
                <field name="sourcing_markup" invisible="not sourcing_vendor_id" required="sourcing_vendor_id" readonly="1"/>
                <field name="purchase_order_type" readonly="state not in ['draft','sent','waiting_approval']"/>
            </field>
            <!-- Sourcing Vendor moved to right column -->
        </field>
    </record>
    <record id="purchase_order_view_tree_inherit_presale" model="ir.ui.view">
        <field name="name">purchase.order.view.list.inherit.presale</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="sourcing_vendor_id" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
