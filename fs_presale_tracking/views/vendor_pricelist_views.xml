<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Vendor Pricelist (Custom) -->
    <record id="view_vendor_pricelist_tree_custom" model="ir.ui.view">
        <field name="name">product.supplierinfo.tree.custom</field>
        <field name="model">product.supplierinfo</field>
        <field name="arch" type="xml">
            <list string="Vendor Pricelists" create="0" delete="0" edit="0" decoration-muted="min_qty &lt;= 0">
                <field name="partner_id"/>
                <field name="product_tmpl_id"/>
                <field name="product_name" optional="hide"/>
                <field name="product_code" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="min_qty" optional="show"/>
                <field name="date_start" optional="hide"/>
                <field name="date_end" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vendor_pricelist_custom" model="ir.actions.act_window">
        <field name="name">Vendor Pricelists (Import)</field>
        <field name="res_model">product.supplierinfo</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_vendor_pricelist_tree_custom"/>
        <field name="context">{}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No vendor pricelists found.
          </p><p>
            Use the Import Wizard to add new vendor pricelists.
          </p>
        </field>
    </record>

    <!-- Menu Item for Wizard (Under Purchase -> Configuration) -->
    <menuitem id="menu_vendor_pricelist_import_wizard"
              name="Import Vendor Pricelist"
              parent="purchase.menu_purchase_config"
              action="action_vendor_pricelist_import_wizard"
              sequence="21"/>

</odoo>
