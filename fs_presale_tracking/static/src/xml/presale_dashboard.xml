<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fs_presale_tracking.PresaleDashboard" owl="1">
        <div class="o_presale_dashboard h-100 overflow-auto p-4" style="background-color: #f8fafc;">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-slate-800 mb-1">Presale Intelligence</h2>
                    <p class="text-muted small mb-0">Real-time performance metrics and procurement tracking</p>
                </div>
                <button class="btn btn-white shadow-sm border" t-on-click="fetchData" style="background: white; border-radius: 8px; padding: 10px 20px;">
                    <i class="fa fa-refresh me-2 text-indigo-600"/>Refresh Dataset
                </button>
            </div>
            
            <!-- Cards Row 1: Primary Metrics -->
            <div class="row g-4 mb-4">
                <!-- Revenue Card (Indigo Gradient) -->
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 12px; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);">
                        <div class="card-body p-4 text-white">
                            <div class="d-flex justify-content-between mb-3 opacity-75">
                                <span class="text-uppercase fw-bold small">Total Revenue</span>
                                <i class="fa fa-money fs-4"/>
                            </div>
                            <h2 class="fw-bold mb-1" t-esc="state.summary.revenue"/>
                            <div class="d-flex align-items-center mt-3">
                                <span class="badge bg-white bg-opacity-25 rounded-pill me-2 px-3">Target: Validated</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Margin Card (Emerald Gradient) -->
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 12px; background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                        <div class="card-body p-4 text-white">
                            <div class="d-flex justify-content-between mb-3 opacity-75">
                                <span class="text-uppercase fw-bold small">Estimated Margin</span>
                                <i class="fa fa-line-chart fs-4"/>
                            </div>
                            <h2 class="fw-bold mb-1" t-esc="state.summary.margin"/>
                            <div class="d-flex align-items-center mt-3">
                                <span class="fw-bold me-2" t-esc="state.summary.margin_pct"/>
                                <span class="small text-white text-opacity-75">of revenue</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- RFQ Card (Amber Gradient) -->
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 12px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                        <div class="card-body p-4 text-white">
                            <div class="d-flex justify-content-between mb-3 opacity-75">
                                <span class="text-uppercase fw-bold small">Active RFQs</span>
                                <i class="fa fa-truck fs-4"/>
                            </div>
                            <h2 class="fw-bold mb-1" t-esc="state.summary.rfqs"/>
                            <div class="d-flex align-items-center mt-3 text-white text-opacity-75 small">
                                <i class="fa fa-clock-o me-1"/> <t t-esc="state.summary.avg_duration"/> avg conversion
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Presales Card (Violet Gradient) -->
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 12px; background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">
                        <div class="card-body p-4 text-white">
                            <div class="d-flex justify-content-between mb-3 opacity-75">
                                <span class="text-uppercase fw-bold small">Total Presales</span>
                                <i class="fa fa-folder-open fs-4"/>
                            </div>
                            <h2 class="fw-bold mb-1" t-esc="state.summary.presales"/>
                            <div class="d-flex align-items-center mt-3 text-white text-opacity-75 small">
                                <i class="fa fa-check-circle me-1"/> <t t-esc="state.summary.done"/> marked as done
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cards Row 2: Secondary / Health Metrics -->
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                     <div class="card shadow-sm border-0 h-100 p-4" style="border-radius: 12px; background: white;">
                        <h6 class="text-slate-500 fw-bold mb-3">Status Distribution</h6>
                        <div class="progress-list d-flex flex-column gap-3">
                            <div t-foreach="state.status_dist" t-as="status" t-key="status.label">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold text-slate-700" t-esc="status.label"/>
                                    <span class="small text-muted" t-esc="status.count"/>
                                </div>
                                <div class="progress" style="height: 6px; border-radius: 3px; background-color: #f1f5f9;">
                                    <div class="progress-bar bg-indigo-500" role="progressbar" 
                                         t-attf-style="width: {{state.summary.presales ? (status.count / state.summary.presales * 100) : 0}}%; background-color: #6366f1;"/>
                                </div>
                            </div>
                        </div>
                     </div>
                </div>
                <div class="col-md-8">
                     <div class="card shadow-sm border-0 h-100 p-4" style="border-radius: 12px; background: white;">
                         <div class="d-flex justify-content-between align-items-center mb-3">
                             <h6 class="text-slate-500 fw-bold">Revenue Trend</h6>
                             <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary active">Last 6 Months</button>
                             </div>
                         </div>
                        <div style="height: 180px; position: relative;">
                            <canvas t-ref="chart"/>
                        </div>
                     </div>
                </div>
            </div>
            
            <!-- Lists & Data Grids -->
            <div class="row g-4">
                <!-- Recent Activity Table -->
                <div class="col-lg-7">
                     <div class="card shadow-sm border-0 h-100 p-4" style="border-radius: 12px; background: white;">
                         <div class="d-flex justify-content-between align-items-center mb-4">
                             <h6 class="text-slate-500 fw-bold">Recent Inquiries</h6>
                             <span class="badge bg-slate-100 text-slate-700 p-2">Showing Latest <t t-esc="state.tables.recent.length"/></span>
                         </div>
                          <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light opacity-75">
                                    <tr>
                                        <th class="border-0">Reference</th>
                                        <th class="border-0">Partner</th>
                                        <th class="border-0">Status</th>
                                        <th class="border-0 text-end">Volume</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.tables.recent" t-as="row" t-key="row.id" style="cursor: pointer;" t-on-click="() => this.openPresale(row.id)">
                                        <td class="fw-bold text-indigo-700" t-esc="row.name"/>
                                        <td class="text-slate-600 fw-medium" t-esc="row.partner"/>
                                        <td>
                                            <span t-attf-class="badge rounded-pill" 
                                                  t-attf-style="background-color: {{row.state == 'Done' ? '#dcfce7' : '#e0e7ff'}}; color: {{row.state == 'Done' ? '#166534' : '#3730a3'}};"
                                                  t-esc="row.state"/>
                                        </td>
                                        <td class="text-end fw-bold text-slate-900" t-esc="row.amount"/>
                                    </tr>
                                </tbody>
                            </table>
                         </div>
                     </div>
                </div>
                
                <!-- Performance Grids -->
                <div class="col-lg-5 d-flex flex-column gap-4">
                    <!-- Top Customers -->
                    <div class="card shadow-sm border-0 p-4 flex-grow-1" style="border-radius: 12px; background: white;">
                         <h6 class="text-slate-500 fw-bold mb-3">Top Customers</h6>
                         <div class="d-flex flex-column gap-3">
                             <div t-foreach="state.tables.customers" t-as="cust" t-key="cust.name" class="d-flex align-items-center justify-content-between">
                                 <div class="d-flex align-items-center">
                                      <div class="flex-shrink-0 bg-slate-100 rounded p-2 me-3" style="width: 40px; text-align: center;">
                                          <t t-esc="cust_index + 1"/>
                                      </div>
                                      <span t-esc="cust.name" class="fw-medium text-slate-700"/>
                                 </div>
                                 <span class="fw-bold text-indigo-600" t-esc="cust.formatted_amount"/>
                             </div>
                         </div>
                    </div>
                    <!-- Top Vendors -->
                    <div class="card shadow-sm border-0 p-4 flex-grow-1" style="border-radius: 12px; background: white;">
                         <h6 class="text-slate-500 fw-bold mb-3">Top Vendors</h6>
                         <div class="d-flex flex-column gap-3">
                             <div t-foreach="state.tables.vendors" t-as="vend" t-key="vend.name" class="d-flex align-items-center justify-content-between">
                                 <div class="d-flex align-items-center">
                                      <div class="flex-shrink-0 bg-slate-100 rounded p-2 me-3" style="width: 40px; text-align: center;">
                                          <t t-esc="vend_index + 1"/>
                                      </div>
                                      <span t-esc="vend.name" class="fw-medium text-slate-700"/>
                                 </div>
                                 <span class="fw-bold text-emerald-600" t-esc="vend.formatted_amount"/>
                             </div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
