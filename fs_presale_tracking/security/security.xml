<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_presale_tracking" model="ir.module.category">
        <field name="name">Presale Tracking</field>
        <field name="description">Category for Presale Tracking module</field>
        <field name="sequence">50</field>
    </record>

    <!-- Presale Tracking Manager Group -->
    <record id="group_presale_tracking_manager" model="res.groups">
        <field name="name">Presale Tracking Manager</field>
<!--        <field name="category_id" ref="module_category_presale_tracking"/>-->
        <field name="comment">Manager can create, edit, delete presale tracking documents and manage all settings.</field>
    </record>

    <!-- Presale Tracking User Group -->
    <record id="group_presale_tracking_user" model="res.groups">
        <field name="name">Presale Tracking User</field>
<!--        <field name="category_id" ref="module_category_presale_tracking"/>-->
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">User can view and edit presale tracking documents.</field>
    </record>

    <!-- Manager implies User -->
    <record id="group_presale_tracking_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_presale_tracking_user'))]"/>
    </record>

    <record id="group_purchase_supervisor" model="res.groups">
        <field name="name">Purchase Supervisor</field>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>


    <record id="group_ecom_sales_manager" model="res.groups">
        <field name="name">E-Com Manager</field>
        <field name="comment">User can create ECommerce Sale Orders and Purchase Orders bypassing Presale Tracking.</field>
    </record>

    <!-- Sample SO User Group -->
    <record id="group_sample_so_user" model="res.groups">
        <field name="name">Sample SO User</field>
        <field name="comment">User can create Sample Sale Orders bypassing Presale Tracking.</field>
    </record>

    <!-- Multi-company Rule for Supplier Pricelist in Presale Tracking -->
    <record id="product_supplierinfo_presale_rule" model="ir.rule">
        <field name="name">Supplier Pricelist: Presale Multi-Company</field>
        <field name="model_id" ref="product.model_product_supplierinfo"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_presale_tracking_user'))]"/>
    </record>
</odoo>

