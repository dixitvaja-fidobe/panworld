<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_presale_link_rfq_wizard_form" model="ir.ui.view">
        <field name="name">presale.link.rfq.wizard.form</field>
        <field name="model">presale.link.rfq.wizard</field>
        <field name="arch" type="xml">
            <form string="Link Tracking Line to RFQ">
                <div class="alert alert-info py-2" role="alert" style="font-size: 0.9rem;">
                    <i class="fa fa-info-circle me-2"/>Select the target RFQ to add this product to.
                </div>
                <sheet>
                    <div class="oe_title mb-3">
                        <label for="title" class="oe_edit_only" string="Linking Product:"/>
                        <h3 class="mt-0">
                            <field name="title" class="text-indigo-600 fw-bold"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Product Context">
                            <field name="line_count" invisible="line_count &lt;= 1"/>
                            <field name="vendor_name" string="Target Vendor"/>
                            <field name="sourcing_vendor_id" readonly="1"/>
                        </group>
                        <group string="Selection">
                            <field name="selection_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="target_po_id"
                                   widget="many2one"
                                   options="{'no_create': True, 'no_open': True}"
                                   context="{'show_presale_link': presale_tracking_id}"
                                   invisible="selection_type == 'new'"
                                   required="selection_type == 'existing'"
                                   class="fw-bold"/>
                        </group>
                    </group>
                    <field name="tracking_line_ids" invisible="1"/>
                    <field name="vendor_id" invisible="1"/>
                    <field name="presale_tracking_id" invisible="1"/>
                    <field name="line_count" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm_link" confirm="Are you sure to link the Purchase RFQ?"
                            string="Link to RFQ" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
