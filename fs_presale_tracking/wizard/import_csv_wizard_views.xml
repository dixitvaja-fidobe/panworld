<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="presale_tracking_import_wizard_form" model="ir.ui.view">
        <field name="name">presale.tracking.import.wizard.form</field>
        <field name="model">presale.tracking.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Sale Data">
                <sheet>
                    <group>
                        <group>
                            <label for="csv_file" string="Select File"/>
                            <div class="o_row">
                                <field name="csv_file" filename="csv_filename" string="Upload your file" widget="binary" class="oe_highlight"/>
                                <field name="csv_filename" invisible="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="delimiter" invisible="not is_csv"/>
                            <field name="is_csv" invisible="1"/>
                            <field name="clear_existing"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import_lines" string="Import" type="object" class="btn-primary"/>
                    <button name="action_export_existing" string="Export existing tracking lines" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

