<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_pricelist_import_wizard_form" model="ir.ui.view">
        <field name="name">vendor.pricelist.import.wizard.form</field>
        <field name="model">vendor.pricelist.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Vendor Pricelist">
                <group>
                    <group>
                        <field name="partner_id" domain="[('supplier_rank', '>', 0)]"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="csv_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </group>
                <div class="alert alert-info" role="status">
                    <p><strong>File Format Expected (Excel or CSV):</strong>
                        <button name="action_download_template" string="Click here to download a sample template" type="object" class="btn-link" style="padding: 0; vertical-align: baseline;"/>
                    </p>
                    <ul>
                        <li>Column Check: <b>ISBN</b> and <b>Price</b> headers are required.</li>
                        <li>Add <b>Discount </b> also if you need.</li>
                        <li>Other columns are ignored.</li>
                    </ul>
                </div>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary" data-hotkey="q"/>
                    <button name="action_download_template" string="Download Template" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vendor_pricelist_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Vendor Pricelist</field>
        <field name="res_model">vendor.pricelist.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_vendor_pricelist_import_wizard"
              name="Import Vendor Pricelist"
              parent="purchase.menu_purchase_config"
              action="action_vendor_pricelist_import_wizard"
              sequence="21"/>
</odoo>
