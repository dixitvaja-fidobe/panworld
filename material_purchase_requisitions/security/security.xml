<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Security Groups Privilege Category -->
        <record model="res.groups.privilege" id="res_groups_privilege_material_purchase">
            <field name="name">Material Purchase</field>
            <field name="sequence">8</field>
            <field name="category_id" ref="base.module_category_supply_chain"/>
        </record>

        <!-- Requisition User - Can create and manage own requisitions -->
        <record id="group_purchase_requisition_user" model="res.groups">
            <field name="name">Requisition User</field>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_material_purchase"/>
            <field name="comment">Users who can create and manage purchase requisitions.</field>
        </record>
        
        <!-- Requisition Approver - Can approve requisitions -->
        <record id="group_purchase_requisition_approver" model="res.groups">
            <field name="name">Requisition Approver</field>
            <field name="implied_ids" eval="[(4, ref('group_purchase_requisition_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_material_purchase"/>
            <field name="comment">Users who can approve or reject purchase requisitions.</field>
        </record>
        
        <!-- Requisition Manager - Full access -->
        <record id="group_purchase_requisition_manager" model="res.groups">
            <field name="name">Requisition Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_purchase_requisition_approver'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_material_purchase"/>
            <field name="comment">Full access to all purchase requisition features.</field>
        </record>
        
        <!-- Access Rules -->
        <record id="purchase_requisition_own_rule" model="ir.rule">
            <field name="name">Employee Material Purchase Requisition Own</field>
            <field name="model_id" ref="model_material_purchase_requisition"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <record id="purchase_requisition_line_employee_rule" model="ir.rule">
            <field name="name">Employee Material Purchase Requisition Lines</field>
            <field name="model_id" ref="model_material_purchase_requisition_line"/>
            <field name="domain_force">[('requisition_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <record id="purchase_requisition_all_rule" model="ir.rule">
            <field name="name">Material Purchase Requisitions All</field>
            <field name="model_id" ref="model_material_purchase_requisition"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_purchase_requisition_user')),
                                        (4, ref('purchase.group_purchase_user'))]"/>
        </record>
        
        <record id="purchase_requisition_line_all_rule" model="ir.rule">
            <field name="name">Material Purchase Requisitions Line All</field>
            <field name="model_id" ref="model_material_purchase_requisition_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_purchase_requisition_user')),
                                        (4, ref('purchase.group_purchase_user'))]"/>
        </record>

    </data>
</odoo>
