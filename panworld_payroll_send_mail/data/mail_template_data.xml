<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="email_template_send_hr_payslip_payroll" model="mail.template">
        <field name="name">Custom Email Template</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="subject">Employee Payslip</field>
        <field name="email_from">{{ user.email_formatted }}</field>
        <field name="email_to">{{ object.employee_id.work_email }}</field>
        <field name="body_html" type="html">
           <div style="margin: 0px; padding: 0px;">
                Hello <t t-out="object.employee_id.name or ''"/>,<br/><br/>
                Your payslip for the month of <t t-out="object.date_from or ''"/> to <t t-out="object.date_to or ''"/> is ready.
                <br/><br/>
                Thank you.
           </div>
        </field>
<!--        <field name="report_template" ref="panworld_payroll_send_mail.action_payslip_report"/>-->
<!--        <field name="report_name">PaySlip</field>-->
    </record>
</odoo>