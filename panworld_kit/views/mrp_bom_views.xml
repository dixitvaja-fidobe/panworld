<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_bom_form_inherit" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.readonly.components</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="is_mrp_manager" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="after">
                <field name="type"/>
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']" position="attributes">
                <attribute name="readonly">is_mrp_manager == False</attribute>
            </xpath>
        </field>
    </record>
</odoo>
