<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_sub_category_view" model="ir.ui.view">
        <field name="name">product.sub.category.panworld</field>
        <field name="model">product.sub.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" />
            </list>
        </field>
    </record>
    <record model="ir.actions.act_window" id="product_sub_category_action">
        <field name="name">Product Sub Category</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.sub.category</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem
        id="menu_product_sub_categ"
        parent="purchase.menu_product_in_config_purchase" sequence="33"
        action="product_sub_category_action"
    />
</odoo>
