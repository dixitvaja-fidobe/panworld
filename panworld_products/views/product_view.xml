<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_form_panworld_inherit" model="ir.ui.view">
        <field name="name">product.form.panworld.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <field name="barcode" position="attributes">
                <attribute name="string">ISBN</attribute>
            </field>
            <xpath expr="//page[@name='general_information']" position='after'>
                <page string='Product Information'>
                    <group>
                        <group>
                            <field name="author_id" options="{'no_create': True}"/>
                            <field name="publisher_id" options="{'no_create': True}"/>
                            <field name="is_not_compare"/>
                            <field name="master_publisher_id" options="{'no_create': True}"/>
                            <field name="uk_wholesaler_id" options="{'no_create': True}"/>
                            <field name="publication_country_id"/>
                            <field name="main_title" />
                            <field name="subtitle" />
                            <field name="interest_age" />
                            <field name="audience_readership" />
                        </group>
                        <group>
                            <field name="subject" />
                            <field name="page" />
                            <field name="edition" />
                            <field name="non_uk_wholesaler_id" options="{'no_create': True}"/>
                            <field name="series" />
                            <field name="book_language_id" />
                            <field name="product_format" readonly='1' />
                            <field name="publication_date" />
                            <field name="status" />
                            <field name="cubiscan_device" />
                        </group>
                    </group>
                </page>
            </xpath>
            <field name="product_format" position="after">
                <field name="barcode" position="move"/>
            </field>
            <field name="categ_id" position="after">
                <field name="sub_category_id" options="{'no_create': True}"/>
            </field>
        </field>
    </record>
    <record id="product_search_panworld_inherit" model="ir.ui.view">
        <field name="name">product.search.panworld.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='group_by_categ_id']" position="after">
                <filter
                        string="Author"
                        name="author_id"
                        context="{'group_by':'author_id'}"
                    />
                    <filter
                        string="Book Language"
                        name="book_language_id"
                        context="{'group_by':'book_language_id'}"
                    />
                    <filter
                        string="Product Format"
                        name="product_format"
                        context="{'group_by':'product_format'}"
                    />
                    <filter
                        string="Status"
                        name="status"
                        context="{'group_by':'status'}"
                    />
            </xpath>
            <xpath expr="//search" position="inside">
                <field name="author_id" />
                <field name="book_language_id" />
                <field name="product_format" />
                <field name="status" />
            </xpath>
        </field>
    </record>
    <record id="product_tree_panworld_inherit" model="ir.ui.view">
        <field name="name">product.tree.panworld.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="author_id" optional="hide" />
                <field name="book_language_id" optional="hide" />
                <field name="main_title" optional="hide" />
            </xpath>
        </field>
    </record>
</odoo>
