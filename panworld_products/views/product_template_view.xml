<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_template_form_panworld_inherit" model="ir.ui.view">
        <field name="name">product.template.form.panworld.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Product Information">
                    <group>
                        <group>
                            <field name="author_id" options="{'no_create': True}" />
                            <field name="publisher_id" options="{'no_create': True}" />
                            <field
                                name="master_publisher_id"
                                options="{'no_create': True}"
                            />
                            <field
                                name="uk_wholesaler_id"
                                invisible="product_variant_count > 1"
                                options="{'no_create': False}"
                            />
                            <field name="publication_country_id" />
                            <field
                                name="main_title"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="subtitle"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="interest_age"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="audience_readership"
                                invisible="product_variant_count > 1"
                            />
                        </group>
                        <group>
                            <field
                                name="subject"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="page"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="edition"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="non_uk_wholesaler_id"
                                invisible="product_variant_count > 1"
                                options="{'no_create': False}"
                            />
                            <field
                                name="series"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="book_language_id"
                                invisible="product_variant_count > 1"
                            />
                            <field name="product_format" />
                            <field
                                name="publication_date"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="status"
                                invisible="product_variant_count > 1"
                            />
                            <field
                                name="cubiscan_device"
                                invisible="product_variant_count > 1"
                            />
                        </group>
                    </group>
                </page>
            </xpath>
            <field name="product_format" position="after">
                <field name="barcode" position="move"/>
            </field>
            <field name="barcode" position="attributes">
                <attribute name="string">ISBN</attribute>
            </field>
            <field name="categ_id" position="after">
                <field name="sub_category_id" options="{'no_create': True}"/>
            </field>
            <field name="default_code" position='attributes'>
                <attribute name="invisible">1</attribute>
            </field>
        </field>
    </record>
</odoo>
