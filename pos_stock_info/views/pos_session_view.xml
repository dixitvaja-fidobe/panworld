<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_form_panworld_account" model="ir.ui.view">
        <field name="name">pos.session.form</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form" />
        <field name="arch" type="xml">
            <!-- # override this button to pass context to set product account base on Sales Journal -->
            <xpath expr="//button[@name='action_pos_session_closing_control']" position="replace">
                <button id="validate_closing_control"
                        name="action_pos_session_closing_control"
                        type="object"
                        string="Close Session &amp; Post Entries"
                        invisible="(state != 'closing_control' and rescue == False) or (state == 'closed' and rescue == True) or state != 'closing_control'"
                        class="oe_highlight" context="{'is_pos_session_id': config_id}"/>
            </xpath>
        </field>
    </record>
</odoo>