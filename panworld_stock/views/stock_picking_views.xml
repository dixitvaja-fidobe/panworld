<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited stock picking Form -->
    <record id="view_picking_form_inherit_panworld_stock" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="replace">
                <field name="origin" invisible="1"/>
                <field name="sale_id" invisible="sale_id == False" readonly="1"/>
                <field name="purchase_id" invisible="purchase_id == False" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="after">
                <field name="is_consolidated_picking" invisible="1" />
                <field
                    name="purchase_ids"
                    string="Purchase Orders"
                    widget="many2many_tags"
                    invisible="is_consolidated_picking == False"
                    domain="[('partner_id', '=', partner_id), ('state', 'in', ['purchase'])]"
                />
                <field name="shipper_stock_added" readonly='1' force_save="1"/>
                <field name="is_imported" invisible="1"/>
            </xpath>
             <xpath expr="//field[@name='move_ids']//list//field[@name='product_id']" position="attributes">
                 <attribute name="width">300px</attribute>
             </xpath>

            <xpath expr="//field[@name='move_ids']//list//field[@name='date_deadline']" position="attributes">
                 <attribute name="width">120px</attribute>
            </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='date']" position="attributes">
                 <attribute name="width">120px</attribute>
             </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='product_uom_qty']" position="after">
                 <field name="forecast_availability" width="100px" optional="hide"/>
             </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='product_uom_qty']" position="attributes">
                 <attribute name="width">100px</attribute>
             </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='quantity']" position="attributes">
                 <attribute name="width">100px</attribute>
             </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='quantity']" position="after">
                 <field name="sml_done_qty" width="100px" optional="hide"/>
             </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='product_id']" position="after">
                <field name="purchase_order_id"
                    readonly="1"
                    force_save="1"
                    column_invisible="parent.is_consolidated_picking == False"/>
            </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='product_id']" position="after">
                <field name="purchase_line_id" force_save="1" column_invisible="1" />
            </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='product_uom']" position="after">
                <field name="remarks" />
                <field name="cancel_reason" optional="hide"/>
                <field name="is_backorder_picking" optional="hide"/>
<!--                <field name="pending_reason" optional="hide" required="state not in ('done', 'draft') or is_backorder_picking == True"/>-->
                <field name="pending_reason" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='description_picking']" position="after">
                <field name="availability_qty" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='move_ids']//list//field[@name='forecast_availability']" position="attributes">
                <attribute name="column_invisible">parent.picking_type_code in ('incoming', 'internal')</attribute>
            </xpath>
            <field name="location_dest_id" position="attributes">
                <attribute name="string">Receiving Warehouse</attribute>
            </field>
            <xpath expr="//label[@for='scheduled_date']" position="replace">
                <div class="o_td_label">
                    <label for="scheduled_date"
                        string="Material Received Date"
                        invisible="picking_type_code == 'outgoing'"/>
                    <label
                        for="scheduled_date"
                        string="Delivery Note Date"
                        invisible="picking_type_code == 'outgoing'"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='location_id']" position="attributes">
                <attribute name="invisible">state == 'done'</attribute>
            </xpath>
        </field>
    </record>

</odoo>
