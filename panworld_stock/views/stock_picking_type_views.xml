<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited stock picking type Form -->
    <record id="view_picking_type_form_inherit_panworld_stock" model="ir.ui.view">
        <field name="name">stock.picking.type.form</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_backorder']" position="after">
                <field name="is_merge_operation" invisible='1'/>
                <field name="is_consolidated_picking" />
            </xpath>
        </field>
    </record>
</odoo>