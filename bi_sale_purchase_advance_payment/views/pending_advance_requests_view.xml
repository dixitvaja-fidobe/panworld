<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pending_advance_requests_tree" model="ir.ui.view">
        <field name="name">view.pending.advance.requests.tree</field>
        <field name="model">pending.advance.requests</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="purchase_id" widget="many2one_clickable"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="po_total"/>
                <field name="po_value"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_id" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_pending_advance_requests" model="ir.actions.act_window">
        <field name="name">Pending Advance Requests</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pending.advance.requests</field>
        <field name="view_id" ref="view_pending_advance_requests_tree"/>
        <field name="view_mode">list</field>
    </record>

    <record id="property_rule" model="ir.rule">
        <field name="name">Pending Advance Payment multi-company</field>
        <field name="model_id" ref="model_pending_advance_requests"/>
        <field eval="True" name="global"/>
        <field name="domain_force">['|',('company_id', 'in', company_ids),('company_id','=',False)]</field>
    </record>

</odoo>