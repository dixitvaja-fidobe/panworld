<odoo>
    <record id="view_pending_advanced_payment_tree" model="ir.ui.view">
        <field name="name">po.advanced.pending.payments.tree</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="purchase_id" widget="many2one_clickable" string="Request PO NO"/>
<!--                <field name="status_custom"/>-->
                <field name="date"/>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="payment_method_line_id"/>
                <field name="partner_id"/>
                <field name="batch_payment_id"/>
                <field name="po_value"/>
                <field name="amount_signed"/>
                <field name="currency_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

     <record  model="ir.ui.view" id="view_account_payment_form_inherit" >
        <field name="name">account.payment.view.inherit</field>
        <field name="model">account.payment</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
             <xpath expr="//field[@name='partner_bank_id']" position="after">
                     <field name="payment_utr_no"
                            invisible="state != 'draft'"/>
                 <field name="file_name" invisible="1"/>
                 <field name="attachment_upload" widget="binary" filename="file_name"
                        invisible="state != 'draft'"/>
             </xpath>
            <xpath expr="//group" position="after">
                <group>
                    <field name="is_advanced_payment" invisible="1"/>
                    <field name="partner_ids" widget="many2many_tags"
                           options="{'no_create': True, 'no_create_edit': True}"
                           invisible="is_advanced_payment != True"/>
                </group>
            </xpath>
        </field>
     </record>

    <record id="account_payments_advance_action" model="ir.actions.act_window">
        <field name="name">PO Advanced Pending Payments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.payment</field>
        <field name="domain">[
            ('payment_type', '=', 'outbound'),
            ('partner_type', '=', 'supplier'),
            ('is_advanced_payment', '=', True), ('is_move_sent', '=', False)]
        </field>
        <field name="view_id" ref="view_pending_advanced_payment_tree"/>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="account_payments_advance_action_menu" name="PO Advanced Pending Payments"
              parent="account.account_reports_management_menu"
              action="bi_sale_purchase_advance_payment.account_payments_advance_action" sequence="10"/>

    <menuitem id="pending_advance_requests_menu" name="Pending Advance Requests"
              parent="account.account_reports_management_menu"
              action="bi_sale_purchase_advance_payment.action_pending_advance_requests" sequence="11"/>
</odoo>