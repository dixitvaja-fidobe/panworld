<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="request_advance_payment_mail_template" model="mail.template">
            <field name="name">Request Advance Payment Mail</field>
            <field name="email_from">{{user.email_formatted}}</field>
            <field name="subject"> Advance Payment Request {{ object.name }}
            </field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>
                        Please process the advance payment as soon as possible for
                        <b>
                            <span t-out="object.name or ''">Ex.PO0001</span>
                        </b>
                        to the
                        <span t-out="object.partner_id.name or ''">Ex.Partner name</span>
                    </p>
                </div>
            </field>
        </record>

        <record id="process_advance_payment_mail_template" model="mail.template">
            <field name="name">Advance Payment Processed Mail</field>
            <field name="email_from">{{user.email_formatted}}</field>
            <field name="subject"> Advance Payment Processed {{ object.purchase_id.name }} {{ object.purchase_id.partner_id.name }}
            </field>
            <field name="model_id" ref="account.model_account_payment"/>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>
                        Advance payment processed for
                        <!--<b>
                            <span t-out="object.purchase_id.name or ''">Ex.PO0001</span>
                        </b>-->

                        <span t-out="object.purchase_id.partner_id.name or ''">Ex.Partner name</span>
                        and the bank payment reference UTR No. is
                        <span t-out="object.payment_utr_no or ''">Ex.XXXX</span>
                        <div style="margin: 16px 0px 16px 0px;">
                            <a t-att-href="ctx.get('base_url')"
                                style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                Purchase Linked
                            </a>
                        </div>
                    </p>
                </div>
            </field>
        </record>


    </data>
</odoo>
