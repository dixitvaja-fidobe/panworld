<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Sales Manager to Search View -->
    <record id="view_order_product_search_inherit_manager" model="ir.ui.view">
        <field name="name">sale.report.search.inherit.manager</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sales_manager_id"/>
            </xpath>
            <xpath expr="//filter[@name='User']" position="after">
                <filter string="Sales Manager" name="SalesManager" context="{'group_by':'sales_manager_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Add Sales Manager to Pivot View -->
    <record id="view_order_product_pivot_inherit_manager" model="ir.ui.view">
        <field name="name">sale.report.pivot.inherit.manager</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="sales_manager_id" type="row" invisible="1"/>
            </xpath>
        </field>
    </record>

     <!-- Add Sales Manager to List View -->
    <record id="sale_report_view_tree_inherit_manager" model="ir.ui.view">
        <field name="name">sale.report.view.list.inherit.manager</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.sale_report_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sales_manager_id" widget="many2one_avatar" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
