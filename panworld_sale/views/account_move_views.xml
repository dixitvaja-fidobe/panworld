<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.form.inherit.panworld.sale</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <field name="academic_year_id"
                       invisible="move_type not in ['out_invoice', 'out_refund']"/>
            </xpath>
        </field>
    </record>
    <record id="account_move_search_view_panworld_sale" model="ir.ui.view">
        <field name="name">account.move.search.inherit.panworld.sale</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="academic_year_id"/>
            </field>
            <xpath expr="//group" position="inside">
                <filter string="Academic Year" name="group_academic_year" domain="[]" context="{'group_by': 'academic_year_id'}"/>
            </xpath>
        </field>
    </record>
    <record id="view_out_invoice_tree_view_panworld_sale" model="ir.ui.view">
        <field name="name">view.out.invoice.tree.panworld.sale</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_partner_display_name']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="partner_id" string="Customer"/>
                <field name="academic_year_id"/>
                <field name="tracking_ref"/>
            </xpath>
            <field name="name" position='attributes'>
                <attribute name="width">150px</attribute>
            </field>
        </field>
    </record>
    <record id="view_out_credit_note_tree_view_panworld_sale" model="ir.ui.view">
        <field name="name">view.out.credit.note.tree.panworld.sale</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_credit_note_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="partner_id" string="Customer"/>
                <field name="academic_year_id"/>
                <field name="tracking_ref"/>
            </xpath>
        </field>
    </record>
