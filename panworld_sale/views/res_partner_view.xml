<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_partner_form_panworld_sale_inherited" model="ir.ui.view">
        <field name="name">res.partner.inherited.panworld_sale</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="property_delivery_carrier_id" position="before">
                <field name="pick_type"/>
            </field>
            <field name="property_delivery_carrier_id" position="attributes">
                <attribute name='domain'>[('carrier_type','=','sale'),'|', ('company_id', '=', False), ('company_id', '=', company_id)]
                </attribute>
                <attribute name='invisible'>pick_type == 'picked_by_customer'</attribute>
            </field>
            <field name="vat" position="after">
                <field name="analytic_account_id"/>
            </field>
        </field>
    </record>
