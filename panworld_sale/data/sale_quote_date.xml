<odoo>
    <record id="action_set_quote_date" model="ir.actions.server">
            <field name="name">Set Quotation Date</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">
                if records:
                    for rec in records:
                        rec.action_set_quotation_date()
            </field>
        </record>
</odoo>
