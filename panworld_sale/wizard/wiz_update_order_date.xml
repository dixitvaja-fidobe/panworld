<odoo>
    <!-- Wiz sale purchase form view -->
    <record id="view_wiz_update_order_form" model="ir.ui.view">
        <field name="name">wiz.update.order.date.form.view</field>
        <field name="model">wiz.update.order.date</field>
        <field name="arch" type="xml">
            <form string="Update Order Date">
                <sheet>
                    <group>
                        <group>
                            <field name="order_date" required="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button
                        string="Update Order Date"
                        name="action_update_order_dare"
                        type="object"
                        class="oe_highlight"
                    />
                    <button string="Cancel" class="btn btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>