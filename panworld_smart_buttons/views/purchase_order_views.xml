<odoo>
    <record id="purchase_order_form_inherit_panworld_smart_buttons" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.panworld.smart.buttons</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_order_lines" type="object" class="oe_stat_button" icon="fa-list">
                    <field name="order_line_count" widget="statinfo" string="Lines"/>
                </button>
            </div>
        </field>
    </record>

    <record id="view_purchase_order_line_tree_panworld" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.panworld</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <list string="Order Lines" create="false" multi_edit="1">
                <field name="product_id"/>
                <field name="name" string="Description"/>
                <field name="product_qty" string="Quantity"/>
                <field name="qty_received" optional="hide"/>
                <field name="qty_invoiced" optional="hide"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="price_unit" string="List Price"/>
                <field name="list_price" string="Unit Price"/>
                <field name="price_subtotal" sum="Total"/>
                <field name="partner_id" optional="hide"/>
                <field name="date_planned" optional="hide"/>
                <field name="tax_ids" widget="many2many_tags" optional="hide"/>
                <field name="price_tax" optional="hide"/>
                <field name="price_total" optional="hide"/>
                <field name="barcode" optional="hide"/>
                <field name="customer_name" optional="hide"/>
                <field name="customer_sales_order" optional="hide"/>
                <field name="related_so" optional="hide"/>
                <field name="remarks" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>
</odoo>
