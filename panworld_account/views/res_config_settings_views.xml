<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_panworld_account" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.account</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='fiscal_localization_setting_container']/../h2" position="replace">
                <h2 invisible="has_accounting_entries != False or has_accounting_entries != True">Fiscal Localization</h2>
            </xpath>
        </field>
    </record>
</odoo>