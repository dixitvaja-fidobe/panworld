<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_form_inherit_panworld_account" model="ir.ui.view">
        <field name="name">view.account.form.inherit.panworld.account</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']//field[@name='account_type']" position="after">
                <field name="deferred_account_id" invisible="internal_group != 'expense'"/>
            </xpath>
        </field>
    </record>
</odoo>
