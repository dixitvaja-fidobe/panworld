<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_panworld_account" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_reference']" position="replace">
            </xpath>
            <xpath expr="(//field[@name='ref'])[1]" position="after">
                <field name="related_bill_ids" widget="many2many_tags"
                       invisible="move_type != 'out_invoice' or out_of_scope == False"
                       required="move_type == 'out_invoice' and out_of_scope == True and state == 'posted'"/>
                <field name="payment_reference"/>
                <field name="credit_note_ref"/>
                <field name="total_weight" invisible="is_service_quotation_bill == True or move_type in ['entry']"/>
                <field name="total_so_weight" readonly="1" invisible="1"/>
                <field name="so_shipping_cost" readonly="1" invisible="1"/>
                <field name="analytic_account_id" readonly="state == 'posted'"/>
                <field name="division_type_id" readonly="state == 'posted'"/>
            </xpath>
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="carrier_id" readonly="state == 'posted'" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="sales_manager_id"
                       invisble="move_type not in ['out_invoice','out_refund']"
                       required="move_type in ['out_invoice','out_refund']"
                       widget="many2one"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="pw_shipping_cost" readonly="state == 'posted'" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="total_sales" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="total_landed_cost" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="total_dcost" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="total_cost" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
                <field name="gp_percentage" invisible="move_type in ['in_invoice', 'in_refund', 'entry']"/>
            </xpath>
            <!-- Invoice Lines -->
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_uom_id']" position="after">
                <field name="weight" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="total_weight" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='name']" position="attributes">
                <attribute name="string">Description</attribute>
                <attribute name="width">120px</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_id']" position="attributes">
                <attribute name="width">150px</attribute>
            </xpath>
<!--            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='account_id']" position="attributes">-->
<!--                <attribute name="width">120px</attribute>-->
<!--            </xpath>-->

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='price_unit']" position="attributes">
                <attribute name="string">List Price</attribute>
                <attribute name="width">100px</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='discount']" position="after">
                <field name="is_allow_to_edit_bill_lines" column_invisible="1"/>
                <field name="list_price" string="Unit Price" column_invisible="parent.move_type in ['in_refund']" readonly="is_allow_to_edit_bill_lines == False and parent.move_type == 'in_invoice'"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='price_subtotal']" position="after">
                <field name="remarks" optional="hide" column_invisible="parent.move_type in ['in_invoice', 'in_refund']"/>
                <field name="course_id" column_invisible="parent.move_type != 'out_invoice'" optional="hide"/>
                <field name="crn" column_invisible="parent.move_type != 'out_invoice'" optional="hide"/>
                <field name="landed_cost" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="marketplace_cost" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="shipping_cost" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="other_cost" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="subtotal_cost" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="gp_percentage" column_invisible="parent.move_type in ['in_invoice', 'in_refund']" optional="hide"/>
                <field name="oos_cost"
                       column_invisible = "parent.move_type != 'out_invoice'"
                       optional="hide"/>
            </xpath>
<!--            <xpath expr="//field[@name='journal_line_ids']//list//field[@name='account_id']" position="after">-->
<!--                <field name="list_price" column_invisible="1"/>-->
<!--            </xpath>-->
            <xpath expr="//group[@id='header_right_group']" position="inside">
<!--                <label for="hsn" string="FOR EXPORT SALES" class="oe_edit_only" invisible="move_type != 'out_invoice'"/>-->
                <field name="country_of_origin_id"  invisible="move_type != 'out_invoice'"/>
                <field name="hsn"  invisible="move_type != 'out_invoice'"/>
            </xpath>
            <xpath expr="//button[@name='action_reverse']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <record id="account_move_search_view_panworld_account" model="ir.ui.view">
        <field name="name">account.move.inherit.panworld.account</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="sales_manager_id"/>
            </field>
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Partner" name="partner" domain="[]" context="{'group_by': 'partner_id'}"/>
                <separator/>
                <filter string="Sales Manager" name="sales_manager" domain="[]" context="{'group_by': 'sales_manager_id'}"/>
            </xpath>
        </field>
    </record>
    <record id="view_out_invoice_tree_view_panworld_account" model="ir.ui.view">
        <field name="name">view.out.invoice.tree.panworld.account</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree" />
        <field name="arch" type="xml">
           <xpath expr="//field[@name='status_in_payment']" position="before">
               <field name="sales_manager_id"/>
           </xpath>
        </field>
    </record>
    <!-- <record id="view_move_form_inherit_panworld_account_asset" model="ir.ui.view">
        <field name="name">account.asset.form</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_expense_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='analytic_tag_ids']" position="after">
                <field name="partner_id"/>
            </xpath>
        </field>
    </record> -->
</odoo>
