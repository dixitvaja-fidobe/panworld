<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- _______________WIZARD FORM VIEW-->
    <record id="sale_manager_update_wizard_view_form" model="ir.ui.view">
        <field name="name">sale.manager.update.wizard.view.form</field>
        <field name="model">update.wiz</field>
        <field name="arch" type="xml">
            <form string="Select the Sales Manager">
                <sheet>
                    <group>
                        <group>
                            <field name="sales_manager_id"/>
                        </group>
                    </group>
                    <footer>
                        <button name="update_sale_manager"
                                type="object"
                                string="Update the selected records"/>
                        <button string="Cancel" class="btn-default"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="partner_and_date_update_wizard_view_form" model="ir.ui.view">
        <field name="name">partner.and.date.update.wizard.view.form</field>
        <field name="model">update.wiz</field>
        <field name="arch" type="xml">
            <form string="Select the Updates">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                    <footer>
                        <button name="update_partner_and_date"
                                type="object"
                                string="Update the selected records"/>
                        <button string="Cancel" class="btn-default"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
