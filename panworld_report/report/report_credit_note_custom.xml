<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Template: Report Credit Note Custom-->
    <template id="report_credit_note_custom">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2 style="font-size: 26px; font-weight: bold; text-align: center; margin-top: 10px; color:black !important;">
                                <span t-if="o.move_type == 'out_refund'">Tax Credit Note</span>
                                <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                            </h2>
                            <table class="table table-sm o_main_table mt32 mb32" name="main_info_table" style="border: none;table-layout: fixed ;">
                        <tbody style="border: none;" >
                        <tr style="border: none; font-size: 14px;">
                            <t t-set="colspan" t-value="2" />
                            <td class="text-left" style="border: none;width: 50% ;">
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;"><span t-field="o.partner_id" /></strong>
                                </span>
                                <br />
                                <span style="color:gray !important;">
                                    <div t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/>
                                    <div style="display:none;">
                                        <address t-field="o.partner_id"
                                            t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;vat&quot;], &quot;no_marker&quot;: True}" />
                                    </div>
                                </span>
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;">TRN:</strong>
                                    <span t-field="o.partner_id.vat" />
                                </span>

                            </td>
                            <td class="text-left" style="border: none;width: 50% ;">
                                <span style="color:gray !important;">
                                    <t t-if="o.move_type == 'out_refund'">
                                        <strong style="color:gray !important;">Credit Note Date:</strong>
                                        <span t-field="o.invoice_date" />
                                    </t>
                                    <t t-if="o.move_type == 'in_refund'">
                                        <strong style="color:gray !important;">Debit Note Date:</strong>
                                        <span t-field="o.invoice_date" />
                                    </t>
                                </span>
                                <br />
                                <span style="color:gray !important;">
                                    <t t-if="o.move_type == 'out_refund'">
                                        <strong style="color:gray !important;">Credit Note Number:</strong>
                                    </t>
                                    <t t-if="o.move_type == 'in_refund'">
                                        <strong style="color:gray !important;">Debit Note Number:</strong>
                                    </t>
                                    <span t-field="o.name" />
                                </span>
                                <br />
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;">Reference Number:</strong>
                                    <span t-field="o.tracking_ref" />
                                </span>
                                <br />
                                <span style="color:gray !important;" t-if="o.rma_id.rma_type == 'customer'">
                                    <strong style="color:gray !important;">SO Number:</strong>
                                    <span t-esc="o.payment_reference"/>
                                    <br />
                                </span>
                                <span style="color:gray !important;" t-if="o.rma_id.rma_type == 'supplier'">
                                    <strong style="color:gray !important;">PO Number:</strong>
                                    <span t-esc="o.rma_id.purchase_order_id.name" />
                                    <br/>
                                </span>
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;">Payment Term:</strong>
                                    <span t-field="o.invoice_payment_term_id.name"/>
                                </span>
                                <br/>
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;">Due Date:</strong>
                                    <span t-field="o.invoice_date_due"/>
                                </span>
                                <br/>
                                <span style="color:gray !important;">
                                    <strong style="color:gray !important;">Currency:</strong>
                                    <span t-field="o.currency_id"/>
                                </span>
                                <br />
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div id="informations" class="row mt32 mb32"
                    style="display: none;">
                    <div class="col-auto mw-100 mb-2" t-if="o.invoice_date"
                        name="invoice_date">
                        <strong style="color:gray !important;">Invoice Date:</strong>
                        <p class="m-0" t-field="o.invoice_date" />
                    </div>
                    <div class="col-auto mw-100 mb-2"
                        t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'"
                        name="due_date">
                        <strong style="color:gray !important;">Due Date:</strong>
                        <p class="m-0" t-field="o.invoice_date_due" />
                    </div>
                    <div class="col-auto mw-100 mb-2" t-if="o.invoice_origin"
                        name="origin">
                        <strong style="color:gray !important;">Source:</strong>
                        <p class="m-0" t-field="o.invoice_origin" />
                    </div>
                    <div class="col-auto mw-100 mb-2" t-if="o.partner_id.ref"
                        name="customer_code">
                        <strong style="color:gray !important;">Customer Code:</strong>
                        <p class="m-0" t-field="o.partner_id.ref" />
                    </div>
                    <div class="col-auto mw-100 mb-2" t-if="o.ref" name="reference">
                        <strong style="color:gray !important;">Reference:</strong>
                        <p class="m-0" t-field="o.ref" />
                    </div>
                </div>
                        <t t-set="display_discount"
                    t-value="any([l.discount for l in o.invoice_line_ids])" />
                    <table class="table table-sm o_main_table"
                    name="invoice_line_table" style="font-size: 12px;">
                    <thead>
                        <tr>
                            <th name="th_sno" class="text-left" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">S.No.</span>
                            </th>
                            <th name="th_description" class="text-left" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">ISBN</span>
                            </th>
                            <th name="th_description" class="text-left" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">Description</span>
                            </th>
                            <th name="orignal_taxable_value" class="text-right" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">Quantity</span>
                            </th>
                            <th name="orignal_taxable_value" class="text-right" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">Unit Price</span>
                            </th>
                            <th name="th_diff" class="text-right" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">VAT</span>
                            </th>
                            <th name="th_diff_on_tax" class="text-right" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">VAT Amount</span>
                            </th>
                            <th name="th_total_amended_supply_value" class="text-right" style="font-size: 14px;font-weight: 900;">
                                <span style="color:gray !important;">Net Total</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="final_total" t-value="0.0"/>
                        <t t-set="total_tax_amount" t-value="0.0"/>
                        <t t-set="diff_total" t-value="0.0"/>
                        <t t-set="current_subtotal" t-value="0" />
                        <t t-set="lines"
                            t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" />
                        <t t-set="qty_count" t-value="0"/>
                        <t t-foreach="lines" t-as="line">
<!--                            <t t-if="not line.display_type">-->
                                <tr>
                                    <td name="account_invoice_sno">
                                        <t t-esc="line_index+1" />
                                    </td>
                                    <td name="isbn">
                                        <t t-esc="line.product_id.barcode" />
                                    </td>
                                    <td name="account_invoice_line_name">
                                        <t t-if="line.product_id">
                                            <span t-field="line.product_id.name"
                                                t-options="{'widget': 'text'}" />
                                        </t>
                                        <t t-if="not line.product_id.id">
                                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                                        </t>
                                    </td>
                                    <td name="quantity" class="text-right">
                                        <!-- <t t-set="orignal_taxable_value_total" t-value="orignal_taxable_value_total + line.orignal_taxable_value"/> -->
                                        <span t-esc="line.quantity" t-options="{'widget': 'float', 'precision': 0}"/>
                                        <t t-set="qty_count" t-value="qty_count+line.quantity" />
                                    </td>
                                    <td name="price_unit" class="text-right">
                                        <span t-esc="line.price_unit" t-options="{'widget': 'float', 'precision': 2}"/>
                                    </td>
                                    <td name="vat" class="text-right">
                                         <!-- <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))"/> -->
                                         <span t-esc="', '.join(map(lambda x: (str(int(x.amount)) + '%'), line.tax_ids))"/>
                                    </td>
                                    <td name="vat_amount" class="text-right">
                                        <!-- <t t-set="vat_amount" t-value="sum(t.amount or 0.0 for t in line.tax_ids)"/>
                                        <t t-set="vat_amount" t-value="(line.price_subtotal * vat_amount)/100"/> -->
                                        <span t-esc="line.l10n_gcc_invoice_tax_amount"  t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td name="total_price" class="text-right">
                                        <span t-esc="float(line.price_total)" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
<!--                            </t>-->
                        </t>
                        </tbody>
                </table>

                    <div class="clearfix">
                        <div id="total" class="row">
                            <div class="col-6 ml-auto">
                                <table class="table table-sm" style="page-break-inside: avoid;">

                                    <!--Tax totals-->
                                    <!-- Manual calculation from invoice lines for compatibility -->
                                    <tr class="border-black o_subtotal">
                                        <td><strong style="color: black !important;">Total Without Taxes</strong></td>
                                        <td class="text-right">
                                            <strong t-esc="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    
                                    <!-- Calculate tax amounts from lines -->
                                    <t t-set="tax_amounts" t-value="{}"/>
                                    <t t-foreach="o.invoice_line_ids" t-as="line">
                                        <t t-foreach="line.tax_ids" t-as="tax">
                                            <t t-set="tax_name" t-value="tax.name"/>
                                            <t t-set="current_tax_amount" t-value="tax_amounts.get(tax_name, 0.0)"/>
                                            <t t-set="dummy" t-value="tax_amounts.update({tax_name: current_tax_amount + line.l10n_gcc_invoice_tax_amount})"/>
                                        </t>
                                    </t>
                                    
                                    <!-- Display tax breakdown -->
                                    <t t-foreach="tax_amounts.items()" t-as="tax_item">
                                        <tr>
                                            <td><span t-esc="tax_item[0]"/></td>
                                            <td class="text-right">
                                                <span t-esc="tax_item[1]" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    
                                    <tr class="border-black o_total">
                                        <td><strong style="color: black !important;">Total</strong></td>
                                        <td class="text-right">
                                            <span t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                    <!--Payments-->
                                    <t t-if="print_with_payments">
                                        <t t-if="o.payment_state != 'invoicing_legacy'">
                                            <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                                            <t t-foreach="payments_vals" t-as="payment_vals">
                                                <tr>
                                                    <td>
                                                        <i class="oe_form_field text-right oe_payment_label">Paid on <t t-esc="payment_vals['date']" t-options='{"widget": "date"}'/></i>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-esc="payment_vals['amount']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="len(payments_vals) > 0">
                                                <tr class="border-black">
                                                    <td><strong>Amount Due</strong></td>
                                                    <td class="text-right">
                                                        <span t-field="o.amount_residual"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </t>
                                    </t>
                                    <tr class="border-black o_subtotal">
                                        <tr class="border-black o_total" style="color: black !important;">
                                            <td><strong style="color: black !important;">Total Units</strong></td>
                                            <td class="text-right">
                                                <strong t-esc="qty_count" t-options="{'widget': 'float', 'precision': 0}"/>
                                            </td>
                                        </tr>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                <h6>Amount in Words : <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/></h6>
                <p t-if="o.narration" name="comment">
                    <div style="font-size: 12px;"><span t-esc="o.narration" /></div>
                </p>
                </div>
            </t>
      </template>

    <template id="credit_note_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang"/>
                <t t-call="panworld_report.report_credit_note_custom" t-lang="lang"/>
            </t>
        </t>
    </template>

    <record id="credit_note_custom_report" model="ir.actions.report">
        <field name="name">Credit Note</field>
        <field name="model">account.move</field>
         <field name="report_type">qweb-pdf</field>
        <field name="report_name">panworld_report.credit_note_custom</field>
        <field name="report_file">panworld_report.credit_note_custom</field>
        <field name="print_report_name">'Credit_Note_%s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>
</odoo>