<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-set='address']" position="replace">
            <t t-set="address" t-value="False"/>
        </xpath>
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//div[hasclass('page')]/table[1]/thead[1]" position="attributes">
            <attribute name="style">display: ;</attribute>
        </xpath>
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">
            <h5 class="text-center" style="color: black !important; margin-top: -5px;">
                <strong>
                    <t t-set="layout_document_title">
                        <center>
                            <span t-if="is_proforma">Pro-Forma Invoice #</span>
                            <span t-elif="doc.state in ['draft', 'sent']">Quotation #</span>
                            <span t-else="doc.state in ['sale', 'cancel']">Sale Order #</span>
                            <span t-field="doc.name">SO0000</span>
                        </center>
                    </t>
                </strong>
            </h5>
            <table>
                <div id="partner" class="row" style="background-color: #F8F5F7;"
                     t-if="doc.state not in ['draft','sent']">
                    <div class="col-4">
                        <strong>Invoice To:</strong>
                        <div t-field="doc.partner_id.name"/>
                        <div t-field="doc.partner_id"
                             t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        <p t-if="doc.partner_id.vat">
                            TRN : <span t-field="doc.partner_id.vat"/>
                        </p>
                    </div>
                    <div class="col-4">
                        <strong>Shipping address:</strong>
                        <div t-field="doc.partner_shipping_id.name"/>
                        <p t-if="doc.partner_shipping_id.vat">
                            TRN : <span t-field="doc.partner_shipping_id.vat"/>
                        </p>
                    </div>
                    <div class="col-4">
                        <div t-if="doc.date_order">
                            <strong>
                                <span t-if="is_proforma">Invoice Date:</span>
                                <span t-elif="doc.state in ['draft', 'sent']">Quotation Date:</span>
                                <span t-else="">Order Date:</span>
                            </strong>
                            <span class="m-0" t-field="doc.date_order" t-options='{"format": "dd/MM/yyyy"}'/>
                        </div>
                        <div>
                            <strong>Doc Number:</strong>
                            <span class="m-0" t-field="doc.name"/>
                        </div>
                        <div>
                            <strong>Reference:</strong>
                            <span class="m-0" t-field="doc.client_order_ref"/>
                        </div>
                        <div>
                            <strong>Payment Terms:</strong>
                            <span class="m-0" t-field="doc.payment_term_id.name"/>
                        </div>
                        <div>
                            <strong>Currency:</strong>
                            <span class="m-0" t-field="doc.currency_id.name"/>
                        </div>
                    </div>
                </div>
                <div id="partner" class="row mt64 mb32" style="background-color: #F8F5F7;"
                     t-if="doc.state in ['draft','sent']">
                    <div class="col-6">
                        <strong>Bill To:</strong>
                        <br/>
                        <strong t-field="doc.partner_id.name"/>
                        <div t-field="doc.partner_id"
                             t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        <p t-if="doc.partner_id.vat">
                            TRN : <span t-field="doc.partner_id.vat"/>
                        </p>
                    </div>
                    <div class="col-6">
                        <div t-if="doc.date_order">
                            <strong>
                                <span t-if="is_proforma">Invoice Date:</span>
                                <span t-elif="doc.state in ['draft', 'sent']">Quotation Date:</span>
                                <span t-else="">Order Date:</span>
                            </strong>
                            <span class="m-0" t-field="doc.date_order" t-options='{"format": "dd/MM/yyyy"}'/>
                        </div>
                        <div>
                            <strong>Payment Terms:</strong>
                            <span class="m-0" t-field="doc.payment_term_id.name"/>
                        </div>
                        <div>
                            <strong>Currency:</strong>
                            <span class="m-0" t-field="doc.currency_id.name"/>
                        </div>
                        <div>
                            <strong>Reference:</strong>
                            <span class="m-0" t-field="doc.customer_sales_order"/>
                        </div>
                    </div>
                </div>
            </table>
        </xpath>
        <xpath expr="//table[@class='o_has_total_table table o_main_table table-borderless']" position="before">
            <div style="width: 100%; max-width: 100%;"/>
        </xpath>
        <xpath expr="//table[@class='o_has_total_table table o_main_table table-borderless']" position="attributes">
            <attribute name="style">table-layout: fixed; width: 100%; font-size: 12px;</attribute>
        </xpath>
        <xpath expr="//table[@class='o_has_total_table table o_main_table table-borderless']" position="after">
            <div></div>
        </xpath>
        <xpath expr="//t[@t-foreach='lines_to_report']" position="before">
            <t t-set="count" t-value="0"/>
            <t t-set="qty_count" t-value="0"/>
            <t t-set="price_reduce"
               t-value="sum(((l.product_uom_qty * l.price_unit) * (l.discount/100)) for l in doc.order_line)"/>
        </xpath>
        <xpath expr="//th[@name='th_description']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_taxes']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_priceunit']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_sr" class="text-center" style="width: 4%;">S No.</th>
            <th name="th_isbn" class="text-center" style="width: 10%;">ISBN</th>
            <th name="th_title" class="text-center" style="width: 20%;">Title</th>
            <t t-if="doc.partner_id.vat == '100276002100003'">
                <th name="th_course" class="text-center">Course ID</th>
                <th name="th_crn" class="text-center">CRN</th>
            </t>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="replace">
            <t t-set="has_grade" t-value="any(line.uk_wholesaler_id for line in doc.order_line)"/>
            <t t-set="has_subject" t-value="any(line.subject_id for line in doc.order_line)"/>
            <t t-set="has_format" t-value="any(line.format for line in doc.order_line)"/>
            <t t-set="has_classification" t-value="any(line.classification for line in doc.order_line)"/>
            <t t-set="has_remarks" t-value="any(line.remarks for line in doc.order_line)"/>
            <th name="th_vat_per" class="text-center" style="text-align:center;width: 4%;">
                <span>VAT</span>
            </th>
            <th name="th_subtotal" class="text-center" style="text-align:center;width: 8%;">
                <span>Total</span>
            </th>
            <th name="th_vat" class="text-center" style="width: 8%;">
                <span>VAT Amount</span>
            </th>
            <th name="th_net" class="text-center" style="width: 8%;">
                <span>Net Total</span>
            </th>
            <t t-if="not env.context.get('proforma', False) and not is_pro_forma">
                <th name="th_grade" class="text-center" t-if="has_grade">
                    <span>Grade</span>
                </th>
                <th name="th_subject" class="text-center" t-if="has_subject">
                    <span>Subject</span>
                </th>
                <th name="th_format" class="text-center" t-if="has_format">
                    <span>Format</span>
                </th>
                <th name="th_classification" class="text-center" t-if="has_classification">
                    <span>Classification</span>
                </th>
                <th name="th_remark" class="text-center" t-if="has_remarks">
                    <span>Remarks</span>
                </th>
            </t>
        </xpath>
        <xpath expr="//th[@name='th_discount']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_quantity']" position="after">
            <th name="th_listprice" class="text-center" style="width: 8%;">List Price</th>
        </xpath>
        <xpath expr="//th[@name='th_priceunit']" position="after">
            <th name="th_discount" t-if="display_discount" class="text-center" style="width: 6%;">
                <span>Disc.%</span>
            </th>
        </xpath>
        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" class="text-center" style="width: 4%;">Qty</th>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//td[@name='td_product_priceunit']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//td[@name='td_product_taxes']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//span[@t-field='line.product_uom_id']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//td[@name='td_product_name']" position="before">
            <td id="s_no" class="text-center" style="width: 3%;">
                <t t-set="count" t-value="count+1"/>
                <t t-esc="count"/>
                <t t-set="qty_count" t-value="qty_count+line.so_qty"/>
            </td>
            <td id="product_isbn" style="width: 15%; white-space: nowrap;">
                <span t-field="line.product_id.barcode"/>
            </td>
            <td id="product_name">
                <span t-field="line.product_id.name"/>
            </td>
            <t t-if="doc.partner_id.vat == '100276002100003'">
                <td name="course_" class="text-center">
                    <span t-esc="line.course_id"/>
                </td>
                <td name="crn" class="text-center">
                    <span t-esc="line.crn"/>
                </td>
            </t>
            <td name="td_quantity" class="text-end" style="width: 4%;">
                <span t-field="line.so_qty" t-options="{'widget': 'float', 'precision': 0}"/>
            </td>
            <td name="td_price_unit" class="text-end">
                <span t-field="line.price_unit"/>
            </td>
            <td name="td_vat_per" class="text-center">
                <t t-set="tax_names" t-value="', '.join([tax.invoice_label for tax in line.tax_ids])"/>
                <span t-out="tax_names if tax_names else '0%'"/>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_product_name']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//td[@name='td_product_subtotal']" position="replace">
            <td name="td_product_subtotal" class="text-end o_price_total">
                <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_product_subtotal']" position="after">
            <t t-set="subtotal_sum" t-value="0"/>
            <t t-set="total_sum" t-value="0"/>
            <td name="vat_amount" class="text-end">
                <span t-esc="float(line.price_total - line.price_subtotal)"
                      t-options='{"widget": "float", "precision": 2}'/>
            </td>
            <td class="text-end o_price_total">
                <t t-set="price_subtotal_sum" t-value="line.so_qty * line.list_price"/>
                <t t-set="subtotal_sum" t-value="subtotal_sum+price_subtotal_sum"/>
                <t t-set="price_total_sum"
                   t-value="price_subtotal_sum + float(line.price_total - line.price_subtotal)"/>
                <span t-esc="price_total_sum" t-options='{"widget": "float", "precision": 2}'/>
                <t t-set="total_sum" t-value="subtotal_sum + doc.amount_tax"/>
            </td>
            <t t-if="not env.context.get('proforma', False) and not is_pro_forma">
                <td name="grade" class="text-center" t-if="has_grade">
                    <span t-esc="line.uk_wholesaler_id.name"/>
                </td>
                <td name="subject" class="text-center" t-if="has_subject">
                    <span t-esc="line.subject_id.name"/>
                </td>
                <td name="format" class="text-center" t-if="has_format">
                    <span t-esc="line.format"/>
                </td>
                <td name="classification" class="text-center" t-if="has_classification">
                    <span t-esc="line.classification"/>
                </td>
                <td name="remark" class="text-center" t-if="has_remarks">
                    <span t-esc="line.remarks"/>
                </td>
            </t>
        </xpath>
        <xpath expr="//div[@name='so_total_summary']" position="after">
            <h6>
                <strong>Amount in Words :</strong>
                <span t-esc="doc.currency_id.amount_to_text(doc.amount_total)"/>
            </h6>
        </xpath>
        <xpath expr="//t[@t-set='tax_totals']" position="before">
            <tr class="border-black o_subtotal" t-if="price_reduce">
                <tr class="border-black o_total" style="color: black !important;">
                    <td>
                        <strong style="color: black !important;">Discount</strong>
                    </td>
                    <td class="text-end">
                        <strong t-esc="price_reduce"
                                t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                    </td>
                </tr>
            </tr>
        </xpath>
        <xpath expr="//span[@t-field='doc.payment_term_id.note']" position="replace"/>
        <xpath expr="//td[@name='td_product_priceunit']" position="replace"/>
    </template>
</odoo>