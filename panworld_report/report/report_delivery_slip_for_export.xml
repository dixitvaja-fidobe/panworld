<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_delivery_document_inherited">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context(lang=o._get_report_lang())"/>
                <t t-set="partner" t-value="o.partner_id or (o.move_ids and o.move_ids[0].partner_id) or False"/>

                <t t-set="address">
                    <div name="div_outgoing_address">
                        <div t-if="o.should_print_delivery_address()">
                            <span>
                                <strong>Delivery Address:</strong>
                            </span>
                            <div t-field="o.move_ids[0].partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                        </div>
                        <div t-elif="o.picking_type_id.code != 'internal' and o.picking_type_id.warehouse_id.partner_id">
                            <span>
                                <strong>Warehouse Address:</strong>
                            </span>
                            <div t-field="o.picking_type_id.warehouse_id.partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                        </div>
                    </div>
                </t>
                <t t-set="information_block">
                    <div class="row">
                        <div class="col-7" name="div_incoming_address">
                            <t t-set="show_partner" t-value="False"/>
                            <div t-if="o.picking_type_id.code=='incoming' and partner">
                                <span>
                                    <strong>Vendor Address:</strong>
                                </span>
                                <t t-set="show_partner" t-value="True"/>
                            </div>
                            <div t-if="o.picking_type_id.code=='outgoing' and partner and partner != partner.commercial_partner_id">
                                <span>
                                    <strong>Customer Address:</strong>
                                </span>
                                <t t-set="show_partner" t-value="True"/>
                            </div>
                            <div t-if="show_partner" name="partner_header">
                                <div t-field="partner.commercial_partner_id"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                                <p t-if="partner.sudo().commercial_partner_id.vat"><t
                                        t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>:
                                    <span t-field="partner.sudo().commercial_partner_id.vat"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </t>
                <div class="page">
                    <h2>
                        <span t-field="o.name"/>
                    </h2>
                    <div class="row mt32 mb32">
                        <div t-if="o.origin" class="col-auto" name="div_origin">
                            <strong>Order:</strong>
                            <p t-field="o.origin"/>
                        </div>
                        <div t-if="o.state" class="col-auto" name="div_sched_date">
                            <strong>Shipping Date:</strong>
                            <t t-if="o.state == 'done'">
                                <p t-field="o.date_done"/>
                            </t>
                            <t t-if="o.state != 'done'">
                                <p t-field="o.scheduled_date"/>
                            </t>
                        </div>
                    </div>
                    <table class="table table-sm" t-if="o.state!='done'" name="stock_move_table">
                        <thead>
                            <tr>
                                <th name="th_sm_product">
                                    <strong>Product</strong>
                                </th>
                                <th name="th_sm_ordered">
                                    <strong>Ordered</strong>
                                </th>
                                <th name="th_sm_quantity">
                                    <strong>Delivered</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="lines" t-value="o.move_ids.filtered(lambda x: x.product_uom_qty)"/>
                            <tr t-foreach="lines" t-as="move">
                                <td>
                                    <span t-field="move.product_id"/>
                                    <p t-if="move.description_picking != move.product_id.name and move.description_picking != move.product_id.display_name">
                                        <span t-field="move.description_picking"/>
                                    </p>
                                </td>
                                <td>
                                    <span t-field="move.product_uom_qty"/>
                                    <span t-field="move.product_uom"/>
                                </td>
                                <td>
                                    <span t-field="move.quantity"/>
                                    <span t-field="move.product_uom"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <table class="table table-sm mt48" t-if="o.move_line_ids and o.state=='done'"
                           name="stock_move_line_table">
                        <t t-set="has_serial_number" t-value="False"/>
                        <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')"
                           groups="stock.group_lot_on_delivery_slip"/>
                        <thead>
                            <tr>
                                <th name="th_sml_product">
                                    <strong>Product</strong>
                                </th>
                                <t name="lot_serial" t-if="has_serial_number">
                                    <th>
                                        Lot/Serial Number
                                    </th>
                                </t>
                                <th name="th_sml_qty_ordered" class="text-center" t-if="not has_serial_number">
                                    <strong>Ordered</strong>
                                </th>
                                <th name="th_sml_quantity" class="text-center">
                                    <strong>Delivered</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- This part gets complicated with different use cases (additional use cases in extensions of this report):
                                    1. If serial numbers are used and set to print on delivery slip => print lines as is, otherwise group them by overlapping
                                        product + description + uom combinations
                                    2. If any packages are assigned => split products up by package (or non-package) and then apply use case 1 -->
                            <!-- If it has destination packages => create sections of corresponding products -->
<!--                            <t t-if="o.has_packages" name="has_packages">-->
<!--                                <t t-set="packages" t-value="o.move_line_ids.mapped('result_package_id')"/>-->
<!--                                <t t-foreach="packages" t-as="package">-->
<!--                                    <t t-call="stock.stock_report_delivery_package_section_line"/>-->
<!--                                    <t t-set="package_move_ids"-->
<!--                                       t-value="o.move_line_ids.filtered(lambda l: l.result_package_id == package)"/>-->
<!--                                    &lt;!&ndash; If printing lots/serial numbers => keep products in original lines &ndash;&gt;-->
<!--                                    <t t-if="has_serial_number">-->
<!--                                        <tr t-foreach="package_move_ids" t-as="move_line">-->
<!--                                            <t t-call="stock.stock_report_delivery_has_serial_move_line"/>-->
<!--                                        </tr>-->
<!--                                    </t>-->
<!--                                    &lt;!&ndash; If not printing lots/serial numbers => merge lines with same product+description+uom &ndash;&gt;-->
<!--                                    <t t-else="">-->
<!--                                        <t t-set="aggregated_lines"-->
<!--                                           t-value="package_move_ids._get_aggregated_product_quantities(strict=True)"/>-->
<!--                                        <t t-call="stock.stock_report_delivery_aggregated_move_ids"/>-->
<!--                                    </t>-->
<!--                                </t>-->
<!--                                &lt;!&ndash; Make sure we do another section for package-less products if they exist &ndash;&gt;-->
<!--                                <t t-set="move_ids"-->
<!--                                   t-value="o.move_line_ids.filtered(lambda l: not l.result_package_id)"/>-->
<!--                                <t t-set="aggregated_lines"-->
<!--                                   t-value="o.move_line_ids._get_aggregated_product_quantities(except_package=True)"/>-->
<!--                                <t t-if="move_ids or aggregated_lines" name="no_package_move_ids">-->
<!--                                    <t t-call="stock.stock_report_delivery_no_package_section_line"-->
<!--                                       name="no_package_section"/>-->
<!--                                    <t t-if="has_serial_number">-->
<!--                                        <tr t-foreach="move_ids" t-as="move_line">-->
<!--                                            <t t-call="stock.stock_report_delivery_has_serial_move_line"/>-->
<!--                                        </tr>-->
<!--                                    </t>-->
<!--                                    <t t-elif="aggregated_lines">-->
<!--                                        <t t-call="stock.stock_report_delivery_aggregated_move_ids"/>-->
<!--                                    </t>-->
<!--                                </t>-->
<!--                            </t>-->
                            <!-- No destination packages -->
<!--                            <t t-else="">-->
                                <!-- If printing lots/serial numbers => keep products in original lines -->
                        <t t-if="has_serial_number">
                            <tr t-foreach="o.move_line_ids" t-as="move_line">
                                <t t-call="stock.stock_report_delivery_has_serial_move_line"/>
                            </tr>
                        </t>
                        <!-- If not printing lots/serial numbers => merge lines with same product -->
<!--                        <t t-else="" name="aggregated_move_ids">-->
<!--                            <t t-set="aggregated_lines"-->
<!--                               t-value="o.move_line_ids._get_aggregated_product_quantities()"/>-->
<!--                            <t t-call="stock.stock_report_delivery_aggregated_move_ids"/>-->
<!--                        </t>-->
<!--                            </t>-->
                        </tbody>
                    </table>
                    <t t-set="backorders"
                       t-value="o.backorder_ids.filtered(lambda x: x.state not in ('done', 'cancel'))"/>
                    <t t-if="o.backorder_ids and backorders">
                        <p class="mt-5">
                            <span>Remaining quantities not yet delivered:</span>
                        </p>
                        <table class="table table-sm" name="stock_backorder_table" style="table-layout: fixed;">
                            <thead>
                                <tr>
                                    <th name="th_sb_product">
                                        <strong>Product</strong>
                                    </th>
                                    <th/>
                                    <th name="th_sb_quantity" class="text-center">
                                        <strong>Quantity</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="backorders" t-as="backorder">
                                    <t t-set="bo_lines"
                                       t-value="backorder.move_ids.filtered(lambda x: x.product_uom_qty)"/>
                                    <tr t-foreach="bo_lines" t-as="bo_line">
                                        <td class="w-auto">
                                            <span t-field="bo_line.product_id"/>
                                            <p t-if="bo_line.description_picking != bo_line.product_id.name and bo_line.description_picking != bo_line.product_id.display_name">
                                                <span t-field="bo_line.description_picking"/>
                                            </p>
                                        </td>
                                        <td/>
                                        <td class="text-center w-auto">
                                            <span t-field="bo_line.product_uom_qty"/>
                                            <span t-field="bo_line.product_uom"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <div t-if="o.signature" class="mt32 ml64 mr4" name="signature">
                        <div class="offset-8">
                            <strong>Signature</strong>
                        </div>
                        <div class="offset-8">
                            <img t-att-src="image_data_uri(o.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                        </div>
                        <div class="offset-8 text-center">
                            <p t-field="o.partner_id.name"/>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="panworld_report.report_delivery_document_export_sales"
              inherit_id="panworld_report.report_delivery_document_inherited">
        <xpath expr="//div[@name='div_outgoing_address']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//div[@name='div_incoming_address']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//h2" position="replace">
            <h2
                    class="text-center"
                    style="color: black !important; margin-bottom: 32px;"
            >Packing Slip
            </h2>
            <div id="partner" class="row mt64 mb32" style="background-color: #F8F5F7;">
                <div class="col-7">
                    <div>
                        <div>
                            <strong>Delivery address:</strong>
                        </div>
                        <strong t-field="o.partner_id.name"/>
                        <div
                                t-field="o.partner_id"
                                t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'
                        />
                        <span t-field="o.partner_id.vat"/>
                    </div>
                </div>
                <div class="col-5">
                    <strong>Date:</strong>
                    <span t-field="o.date_done"/>
                    <br/>
                    <strong>Doc Number:</strong>
                    <span t-field="o.name"/>
                    <br/>
                    <strong>Reference:</strong>
                    <span t-field="o.origin"/>
                    <br/>
                    <strong>LPO:</strong>
                    <span t-field="o.customer_sales_order"/>
                    <br/>
                    <br/>
                    <br/>
                </div>
            </div>
        </xpath>
        <xpath expr="//table[@name='stock_move_table']" position="before">
            <t t-set="count" t-value="0"/>
            <t t-set="qty_count" t-value="0"/>
        </xpath>
        <xpath expr="//table[@name='stock_move_table']" position="attributes">
            <attribute name="t-if">o.state!='cancel'</attribute>
        </xpath>
        <xpath expr="//div[@name='div_origin']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//div[@name='div_sched_date']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_sm_product']" position="before">
            <th name="th_sr">
                <strong>S No.</strong>
            </th>
            <th name="th_isbn">
                <strong>ISBN</strong>
            </th>
            <th name="th_title">
                <strong>Title</strong>
            </th>
            <th name="th_qty" class="text-right">
                <strong>Quantity</strong>
            </th>
        </xpath>
        <xpath expr="//th[@name='th_sm_product']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_sm_ordered']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//th[@name='th_sm_quantity']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath
                expr="//table[@name='stock_move_table']/tbody/tr/td[1]"
                position="before"
        >
            <td id="s_no">
                <t t-set="count" t-value="count+1"/>
                <t t-esc="count"/>
                <t t-set="qty_count" t-value="qty_count+move.product_uom_qty"/>
            </td>
            <td id="product_code">
                <span t-field="move.product_id.default_code"/>
            </td>
            <td id="product_name">
                <span t-field="move.product_id.name"/>
            </td>
            <td id="quantity" class="text-right">
                <span t-field="move.product_uom_qty" t-options="{'widget': 'float', 'precision': 0}"/>
            </td>
        </xpath>
        <xpath
                expr="//table[@name='stock_move_table']/tbody/tr/td[5]"
                position="attributes"
        >
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath
                expr="//table[@name='stock_move_table']/tbody/tr/td[6]"
                position="attributes"
        >
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath
                expr="//table[@name='stock_move_table']/tbody/tr/td[7]"
                position="attributes"
        >
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//table[@name='stock_move_line_table']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//table[@name='stock_move_line_table']" position="after">
            <div class="clearfix" name="so_total_summary">
                <div id="total" class="row" name="total">
                    <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ml-auto">
                        <table class="table table-sm">
                            <!-- Tax totals -->
                            <!-- <t t-set="tax_totals" t-value="json.loads(doc.tax_totals_json)"/> -->
                            <!-- <t t-call="account.document_tax_totals"/> -->
                            <tr class="border-black o_subtotal">
                                <tr class="border-black o_total" style="color: black !important;">
                                    <td>
                                        <strong style="color: black !important;">Total Quantity</strong>
                                    </td>
                                    <td class="text-right">
                                        <strong t-esc="qty_count" t-options="{'widget': 'float', 'precision': 0}"/>
                                    </td>
                                </tr>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <p t-if="not is_html_empty(o.note)" name="note">
                <span t-field="o.note"/>
            </p>
            <t t-set="o" t-value="o.with_context(lang=lang, is_delivery_ship=True)"/>

            <!--             <div class="mt8">Received By:</div>
                        <div style="margin-left: 12px;">Name:</div>
                        <div style="margin-left: 12px;">Date:</div>
                        <div style="margin-left: 12px;">Sign &amp; Stamp:</div> -->
        </xpath>
        <xpath expr="//t[@t-set='backorders']" position="replace">
            <t t-set="backorders" t-value=""/>
        </xpath>
        <xpath expr="//div[@class='page']" position="after">
            <style>
                .col-auto {
                display: none;
                }
            </style>
        </xpath>
    </template>

    <template id="panworld_report.report_delivery_slip_for_export">
        <t t-foreach="docs" t-as="o">
            <t t-call="panworld_report.report_delivery_document_export_sales" t-lang="o._get_report_lang()"/>
        </t>
    </template>

    <record id="panworld_report.action_report_delivery_export_custom_report" model="ir.actions.report">
        <field name="name">Export Sales Delivery Slip - PDF</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">panworld_report.report_delivery_slip_for_export</field>
        <field name="report_file">panworld_report.report_delivery_slip_for_export</field>
        <field name="print_report_name">'Delivery Slip - %s - %s -Export Sales' % (object.partner_id.name or '',
            object.name)
        </field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
</odoo>