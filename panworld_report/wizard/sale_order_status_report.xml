<odoo>
    <record id="sale_order_status_report_view_form" model="ir.ui.view">
        <field name="name">sale.order.status.report.view.form</field>
        <field name="model">sale.order.status.report</field>
        <field name="arch" type="xml">
            <form string="sale_order_status_report_form">
                <sheet>
                    <group name="date_group">
                        <group>
                            <label for="start_date" string="Date"/>
                            <div class="w-100">
                                <div class="o_row">
                                    <field name="start_date" widget="daterange"
                                           options="{'related_end_date': 'end_date'}"/>
                                    <i class="fa fa-long-arrow-right mx-2 oe_edit_only" aria-label="Arrow icon"
                                       title="Arrow"/>
                                    <field name="end_date" widget="daterange"
                                           options="{'related_start_date': 'start_date'}"/>
                                </div>
                            </div>
                        </group>
                        <group>
                            <!--                            <field name="end_date"/>-->
                        </group>
                    </group>
                    <group name="group_2">
                        <group>
                            <field name="division_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="so_status"/>
                        </group>
                    </group>
                    <group>
                        <field name="so_ids" widget="many2many_tags"/>
                        <field name="partner_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <footer>
                    <button name="export_so_data" string="Export" class="oe_highlight" type="object"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="sale_oreder_status_report_action" model="ir.actions.act_window">
        <field name="name">Sale Order Status Report</field>
        <field name="res_model">sale.order.status.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sale_order_status_report_view_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="sale_order_status" name="Sale Order Status" parent="sale.menu_sale_report"
              action="panworld_report.sale_oreder_status_report_action" sequence="301"/>
</odoo>