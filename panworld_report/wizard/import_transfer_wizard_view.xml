<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="views_import_transfers_wizard" model="ir.ui.view">
        <field name="name">import.transfers.wizard.form</field>
        <field name="model">import.transfers.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Transfers">
                <group>
                    <group>
                        <field name="file" filename="name"/>
                    </group>
                    <group>
                        <field name="sample_file" filename="file_name" readonly="1"
                               invisible="sample_file == False"/>
                        <field name="file_name" invisible="1" />
                        <button string="Download Sample File" name="download_sample_file"
                                class="oe_highlight" type="object"/>
                    </group>
                </group>
                <footer>
                    <button name="import_transfers" string="Import" type="object" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="actions_import_transfers_wizard" model="ir.actions.act_window">
        <field name="name">Internal Transfer-Bulk</field>
        <field name="res_model">import.transfers.wizard</field>
        <field name="view_id" ref="views_import_transfers_wizard" />
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_import_transfers_wizard"
        action="actions_import_transfers_wizard"
        parent="stock.menu_stock_warehouse_mgmt"
        groups="stock.group_stock_manager"
        sequence="10"
    />
</odoo>