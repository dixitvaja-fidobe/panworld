<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
       <xpath expr="//tbody" position="inside">
           <tr/>
            <tr t-if="totals.po_total !== undefined">
                <td class="o_td_label">
                    <label class="o_form_label o_tax_total_label">PO Total</label>
                </td>
                <td class="o_list_monetary">
                    <span 
                        t-out="formatMonetary(totals.po_total)" 
                        style="font-size: 1.1em; font-weight: bold; white-space: nowrap;"
                    />
                </td>
            </tr>
        </xpath>
    </t>
</templates>
