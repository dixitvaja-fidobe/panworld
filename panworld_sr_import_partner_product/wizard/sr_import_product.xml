<odoo>
    <data>
        <record id="sr_import_product_form_wizard" model="ir.ui.view">
            <field name="name">sr.import.product.form.wizard</field>
            <field name="model">import.product</field>
            <field name="arch" type="xml">
                <form string="Import Product">
                    <group>
                        <group>
                            <field name="file"  filename="file_name" />
                        </group>
                        <group>
                            <field
                                name="sample_file"
                                filename="file_name"
                                readonly="1"
                                invisible="sample_file == False"
                            />
                            <field name="file_name" invisible="1" />
                            <button
                                string="Download Sample File"
                                name="download_sample_file"
                                class="oe_highlight"
                                type="object"
                            />
                            <button
                                string="Download All ISBNs"
                                name="download_all_products"
                                type="object"
                            />
                        </group>
                    </group>
                    <footer>
                        <button
                            name="import_product"
                            string="Import"
                            type="object"
                            class="oe_highlight"
                        />
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_import_product" model="ir.actions.act_window">
            <field name="name">Import Product</field>
            <field name="res_model">import.product</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'import_product':True,'update_product':False}</field>
        </record>
        <record id="action_import_product_with_update" model="ir.actions.act_window">
            <field name="name">Update Product</field>
            <field name="res_model">import.product</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'import_product':False,'update_product':True}</field>
        </record>
        <menuitem
            action="action_import_product"
            id="menu_import_product"
            parent="stock.menu_stock_inventory_control"
            sequence="10"
        />
        <menuitem
            action="action_import_product_with_update"
            id="menu_import_product_with_update"
            parent="stock.menu_stock_inventory_control"
            sequence="11"
        />
    </data>
</odoo>
