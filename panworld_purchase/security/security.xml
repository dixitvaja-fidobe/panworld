<?xml version="1.0"?>
<odoo>
    <record model="ir.rule" id="multi_company_purchase_shipping_options_rule">
        <field name="name">Multi Company Purchase Shipping Options Rule</field>
        <field name="model_id" ref="model_purchase_shipping_options_rule"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>

    <record model="ir.rule" id="purchase_tracker_report_comp_rule">
        <field name="name">Purchase Tracker multi-company</field>
        <field name="model_id" ref="model_purchase_tracker_report"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>


