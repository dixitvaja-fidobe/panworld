<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="purchase_executive_default_tier_definition" model="tier.definition">
        <field name="model_id" ref="model_purchase_order" />
        <field name="name">Purchase Executive Approval</field>
        <field name="definition_type">domain</field>
        <field name="definition_domain">[
            ('amount_total','&lt;',8000),
            ('partner_id.is_validation_exempt', '=', False)]</field>
        <field name="review_type">group</field>
        <field name="reviewer_group_id" ref='purchase.group_purchase_user' />
    </record>
    <record id="purchase_manager_default_tier_definition" model="tier.definition">
        <field name="model_id" ref="model_purchase_order" />
        <field name="name">Purchase Manager Approval</field>
        <field name="definition_type">domain</field>
        <field name="definition_domain">[
            ('amount_total', '&gt;', 8000),
            ('amount_total','&lt;',80000),
            ('partner_id.is_validation_exempt', '=', False)]</field>
        <field name="review_type">group</field>
        <field name="reviewer_group_id" ref='purchase.group_purchase_manager' />
    </record>
    <record id="purchase_finance_default_tier_definition" model="tier.definition">
        <field name="model_id" ref="model_purchase_order" />
        <field name="name">Finance/MD Approval</field>
        <field name="definition_type">domain</field>
        <field name="definition_domain">[
            ('amount_total', '&gt;', 80000),
            ('partner_id.is_validation_exempt', '=', False)]</field>
        <field name="review_type">group</field>
        <field name="reviewer_group_id" ref='account.group_account_manager' />
    </record>
</odoo>
