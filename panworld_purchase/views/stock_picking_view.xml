    <record id="vpicktree_inherit_bill_shipping_fields" model="ir.ui.view">
        <field name="name">vpicktree.inherit.add.bill.shipping.fileds</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="before">
                <field name="doc_nb_console" optional="show"/>
                <field name="boe_date" optional="show"/>
                <field name="boe_no" optional="show"/>
                <field name="bill_nb" optional="show"/>
                <field name="ship_no" optional="show"/>
                <field name="ready_for_scan_1" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="after">
<!--                <field name="bill_quantity" optional="show"/>-->
                <field name="bill_value" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_internal_search_panworld_purchase" model="ir.ui.view">
        <field name="name">stock.picking.search.panworld.search</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <field name="picking_type_id" position="after">
                <field name="ship_no"/>
            </field>
<!--            <filter name="picking_type" position="after">-->
<!--                <filter string="Division Type" name="division_type" domain="[]" context="{'group_by':'division_type_id'}"/>-->
<!--            </filter>-->
        </field>
    </record>
