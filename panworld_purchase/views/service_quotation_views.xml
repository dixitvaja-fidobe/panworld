<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="action_service_quotation_panworld_purchase" model="ir.actions.act_window">
            <field name="name">Service Quotation</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">tree,kanban,form,pivot,graph,calendar,activity</field>
            <field name="view_id" ref="purchase.purchase_order_view_tree"/>
            <field name="domain">[('is_service_quotation', '=', True)]</field>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="context">{'default_is_service_quotation': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No purchase order found. Let's create one!
                </p>
                <p>
                    Once you ordered your products to your supplier, confirm your request for quotation and it will turn into a purchase order.
                </p>
            </field>
        </record>
        <menuitem id="menu_service_quotation_panworld_purchase"
            action="action_service_quotation_panworld_purchase"
            parent="purchase.menu_procurement_management"
            sequence="10"
        />
        <record id="purchase.purchase_rfq" model="ir.actions.act_window">
            <field name="domain">[('is_service_quotation', '=', False)]</field>
        </record>
        <record id="purchase.purchase_form_action" model="ir.actions.act_window">
            <field name="domain">[('state','in',('purchase', 'done')),('is_service_quotation', '=', False)]</field>
        </record>
    </data>
</odoo>
