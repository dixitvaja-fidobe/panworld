<odoo>
    <record id="purchase_shipping_options_rule_tree" model="ir.ui.view">
        <field name="name">purchase.shipping.options.rule.tree</field>
        <field name="model">purchase.shipping.options.rule</field>
        <field name="arch" type="xml">
            <list string="Shipping Options" editable="bottom">
                <field name="name" />
                <field
                    name="picking_type_id"
                    options="{'no_open': True, 'no_create': True}"
                />
                <field name="default_option" />
                <field name="is_grn_tracking"/>
                <field name="is_via_shipper"/>
                <field
                    name="company_id"
                    options="{'no_open': True, 'no_create': True}"
                />
            </list>
        </field>
    </record>
    <record id="action_purchase_shipping_options" model="ir.actions.act_window">
        <field name="name">Purchase Shipping Options</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.shipping.options.rule</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="purchase_shipping_options_rule_tree" />
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to set a new type for purchase Shipping Options.
            </p>
        </field>
    </record>
    <menuitem
        id="purchase_shipping_options_rule_menu"
        parent="purchase.menu_purchase_config"
        sequence="41"
        action="action_purchase_shipping_options"
    />
</odoo>
