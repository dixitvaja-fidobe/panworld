<!--            <field name="name">Purchase Tracker</field>-->
<!--            <field name="type">ir.actions.server</field>-->
<!--            <field name="model_id" ref="model_purchase_order"/>-->
<!--            <field name="state">code</field>-->
<!--            <field name="code">model.print_report()</field>-->
<!--        </record>-->
<!--    </data>-->



    <record id="purchase_tracker_action" model="ir.actions.act_window">
        <field name="name">Purchase Tracker</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.tracker.report</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_filter_po_date': 1}</field>
    </record>

    <!-- This Menu Item must have a parent and an action -->
    <menuitem id="purchase_tracker" name="Purchase Tracker" parent="purchase.purchase_report_main" action="purchase_tracker_action" sequence="4"/>

</odoo>

