<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="bill_variance_view_form" model="ir.ui.view">
        <field name="name">bill.variance.form</field>
        <field name="model">bill.variance</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field
                            name="product_id"
                            domain="[('is_variance_product', '=', True)]"
                        />
                    </group>
                </group>
                <footer>
                    <button
                        name="button_confirm"
                        type="object"
                        string="Add Difference"
                        class="btn-primary"
                    />
                </footer>
            </form>
        </field>
    </record>
</odoo>
