<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record
        id="product_template_form_panworld_bill_variance_inherit"
        model="ir.ui.view"
    >
        <field name="name">product.template.form.bill.variance.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="is_variance_product" />
                    <label for="is_variance_product" />
                </span>
            </xpath>
        </field>
    </record>
</odoo>
