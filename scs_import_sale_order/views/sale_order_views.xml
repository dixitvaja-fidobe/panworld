<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_order_form_inherit_import_sale_order" model="ir.ui.view">
        <field name="name"> sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_imported" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='name']" position="after">
                <field name="csn_no" optional="hide"/>
                <field name="word_count" optional="hide"/>
                <field name="cost_per_unit" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
