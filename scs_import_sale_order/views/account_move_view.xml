<odoo>
    <record id="inherit_arbtech_view_move_form" model="ir.ui.view">
        <field name="name">inherit.arbtech.view.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='name']" position="after">
                <field name="csn_no" optional="hide"/>
                <field name="word_count" optional="hide"/>
                <field name="cost_per_unit" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
