<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="import_sale_data_wizard_view" model="ir.ui.view">
            <field name="name">Import Sale Data Wizard</field>
            <field name="model">import.sale.data.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="data_import_file" />
                        </group>
                        <group>
                            <field
                                name="sample_file"
                                filename="file_name"
                                readonly="1"
                                invisible="sample_file == False"
                            />
                            <field name="file_name" invisible="1" />
                            <button
                                string="Download Blank Sample file"
                                name="download_sample_file"
                                class="oe_highlight"
                                type="object"
                            />
                        </group>
                    </group>
                    <footer>
                        <button
                            string="Import"
                            name="import_data"
                            class="oe_highlight"
                            type="object"
                        />
                        <button
                            string="Export existing SO lines"
                            name="export_data"
                            class="oe_highlight"
                            type="object"
                        />
                    </footer>
                </form>
            </field>
        </record>
        <record id="import_sale_data_action" model="ir.actions.act_window">
            <field name="name">Import Sale Data</field>
            <field name="res_model">import.sale.data.wizard</field>
            <field name="target">new</field>
            <field name="view_id" ref="import_sale_data_wizard_view" />
            <field name="view_mode">form</field>
        </record>
    </data>
</odoo>
