<?xml version="1.0"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_default_customer" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.default.customer</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="95"/>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='down_payment_product']" position="after">
                <setting string="Default Customer" help="Customer automatically assigned to a POS order when the 'Can invoice' option is enabled.">
                    <field name="pos_default_customer_id"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
