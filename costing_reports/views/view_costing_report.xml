<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_costing_reports_form" model="ir.ui.view">
        <field name="name">costing.report.form</field>
        <field name="model">costing.report</field>
        <field name="arch" type="xml">
            <form create="0">
                <header>
                    <button name="action_costing_average_report" string="Average-Cost based"
                                    data-hotkey="v"
                                    type="object" class="btn-primary"/>
                    <button name="action_costing_purchase_report" string="Purchase-Price based"
                            data-hotkey="v"
                            type="object" class="btn-primary"/>
                    <button name="action_all_filter_remove" string="Remove Filters"
                                    data-hotkey="v"
                                    type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" invisible="1"/>
                        <label for="date_from" string="Date"/>
                        <div class="oe_inline">
                            <field name="date_from" class="mr8 oe_inline" />
                            <strong class="mr8 oe_inline">To</strong>
                            <field name="date_to" class="oe_inline" />
                        </div>
                        <field name="division_ids" widget="many2many_tags"/>
                        <field name="partner_ids" widget="many2many_tags"/>
                        <field name="cso_reference"/>
                        <field name="sale_ids" widget="many2many_tags"/>
                        <field name="invoice_ids" widget="many2many_tags"/>
                        <field name="salesman_ids" widget="many2many_tags"  />
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>

    </record>

