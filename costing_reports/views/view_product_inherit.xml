<odoo>
    <record id="view_product_template_inherit_form_1" model="ir.ui.view">
        <field name="name">view.product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="is_discount_product"/>
                    <label for="is_discount_product"/>
                </span>

            </xpath>
        </field>
    </record>

    <record id="view_product_product_inherit_form_1" model="ir.ui.view">
        <field name="name">view.product.product.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <field name="is_discount_product"/>
                <label for="is_discount_product"/>
            </xpath>
        </field>
    </record>


</odoo>