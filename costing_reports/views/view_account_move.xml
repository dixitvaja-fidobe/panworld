<odoo>
     <record id="view_account_move_form_inherit_costing" model="ir.ui.view">
        <field name="name">view.account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="tracking_number_id" string="Tracking Number" invisible="move_type != 'out_invoice'"/>
                <field name="tracking_number_bill_id" string="Tracking Number" invisible="move_type != 'in_invoice'"/>
                <field name="related_invoice_id" invisible="move_type != 'out_refund'"/>
                <field name="rma_id" readonly="state == 'posted'"/>
            </xpath>
            <xpath expr="//field[@name='line_ids']/list/field[@name='display_type']" position="after">
                <field name="weight_qty" column_invisible="1"/>
                <field name="shipping_cost_per_product" column_invisible="1"/>
                <field name="move_type" column_invisible="1"/>
                <field name="product_weight" column_invisible="1"/>
                <field name="tracking_number_id" force_save="1" column_invisible="parent.move_type != 'out_invoice'" string="Tracking Number" optional="hide"/>
                <field name="bill_tracking_number_id" force_save="1" column_invisible="parent.move_type != 'in_invoice'" string="Tracking Number" optional="show"/>
                <field name="tracking_journal_item_flag" column_invisible="1"/>
                <field name="journal_tracking_number_id" force_save="1" string="Tracking Number" optional="hide"/>
                <field name="move_type" column_invisible="1"/>
                <field name="bill_tracking_number_id" force_save="1" column_invisible="1" string="Bill Tracking Number" optional="hide"/>
                <field name="cumulated_balance" force_save="1" string="Cumulated Balance" readonly="1" optional="hide"/>
            </xpath>
        </field>
     </record>
    <record id="view_in_invoice_bill_tree_inherit_costing_reports" model="ir.ui.view">
        <field name="name">view.account.move.tree.inherit.costing.reports</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="journal_id" optional="show"/>
                <field name="tracking_number_bill_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
