<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tracking_number_tree" model="ir.ui.view">
        <field name="name">tracking.number.form</field>
        <field name="model">tracking.number</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cost"/>
            </list>
        </field>
    </record>
    <record id="view_tracking_number_search" model="ir.ui.view">
        <field name="name">tracking.number.search.view</field>
        <field name="model">tracking.number</field>
        <field name="arch" type="xml">
            <search string="Tracking Number">
                <field name="name"/>
                <field name="ship_no"/>
                <field name="create_uid"/>
            </search>
        </field>
    </record>
    <record id="view_tracking_number_form" model="ir.ui.view">
        <field name="name">tracking.number.form</field>
        <field name="model">tracking.number</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="ship_no"/>
                        <field name="boe_no"/>
                        <field name="boe_date"/>
                        <field name="ready_to_scan"/>
                        <field name="cost"/>
                    </group>
                    <notebook>
                        <page string="Invoices">
                            <group>
                                <field name="total_inv_weight"/>
                                <field name="inv_cost_weight"/>
                            </group>
                                <field name="invoice_line_ids" domain="[('move_type', '=', 'out_invoice')]">
                                    <list create="false" edit="false" delete="false">
                                        <field name="move_id" string="Invoice Number"/>
                                        <field name="partner_id"/>
                                        <field name="invoice_date" string="Invoice Date"/>
                                        <field name="invoice_date_due"/>
                                        <field name="product_id"/>
                                        <field name="quantity" optional="hide"/>
                                        <field name="company_id"/>
                                        <field name="product_weight" optional="hide"/>
                                        <field name="weight_qty" optional="hide"/>
                                        <field name="shipping_cost_per_product" optional="hide"/>
                                        <field name="price_subtotal" optional="hide"/>
                                        <field name="price_total" optional="hide"/>
                                    </list>
                                </field>
                        </page>
                        <page string="Bills">
                            <group>
                                <group>
                                    <field name="total_bill_weight"/>
                                    <field name="bill_cost_weight"/>
                                </group>
                                <group>
                                    <field name="consolidated_weight"/>
                                </group>
                            </group>
                            <field name="bill_line_ids" domain="[('move_type', '=', 'in_invoice')]">
                                <list create="false" edit="false" delete="false">
                                    <field name="move_id" string="Invoice Number"/>
                                    <field name="partner_id" force_save='1'/>
                                    <field name="invoice_date" string="Invoice Date"/>
                                    <field name="invoice_date_due"/>
                                    <field name="product_id"/>
                                    <field name="quantity" optional="hide"/>
                                    <field name="company_id"/>
                                    <field name="product_weight" optional="hide"/>
                                    <field name="weight_qty" optional="hide"/>
                                    <field name="shipping_cost_per_product" optional="hide"/>
                                    <field name="price_subtotal"/>
                                    <field name="price_total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Journals">
                             <group>
                                <field name="total_debit_amount"/>
                            </group>
                            <field name="journal_line_ids" domain="[('move_type', '=', 'entry')]">
                                <list create="false" edit="false" delete="false">
                                    <field name="account_id"/>
<!--                                    <field name="journal_tracking_number_id"/>-->
                                    <field name="debit"/>
                                </list>
                            </field>
                        </page>
                        <page string="Costing">
                            <group>
                                <group>
                                    <field name="shipping_inward_total"/>
                                    <field name="shipping_clearance_total"/>
                                    <field name="weight_comparison"/>
                                    <field name="shipping_inward_kgs"/>
                                    <field name="shipping_clearance_kgs"/>
                                    <field name="total_shipping_charges_kgs"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
<!--                <div class="oe_chatter">-->
<!--                    <field name="message_follower_ids"/>-->
<!--                    <field name="activity_ids"/>-->
<!--                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>-->
<!--                </div>-->
            </form>
        </field>

    </record>
    <record id="action_tracking_number" model="ir.actions.act_window">
        <field name="name">Tracking Number</field>
        <field name="res_model">tracking.number</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_tracking_number_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                   Generate Tracking Number
            </p>
        </field>
    </record>
    <menuitem id="menu_tracking_number" name="Tracking Number" action="action_tracking_number"  parent="purchase.menu_procurement_management" sequence="20"/>
</odoo>
