<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_inherit_landed_cost" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.landed.cost</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="is_landed_cost_payment" invisible="1"/>
                <field name="landed_cost_ids" widget="many2many_tags" invisible="is_landed_cost_payment == False" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
