<odoo>

    <record id="stock_pick_form_inherit_shipping_info" model="ir.ui.view">
        <field name="name">panworld.stock.picking.form.shipping.info</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="panworld_purchase.view_stock_picking_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='shipping_info']//field[@name='carrier_id']" position="after">
<!--                <field name="grn_tracking_number_id"/>-->
                <field name="different_shipment" invisible="purchase_id == False"/>
                <field name="grn_tracking_number_id" required="different_shipment == True"
                                                     readonly="different_shipment == False"/>
            </xpath>
        </field>
    </record>


    <record id="stock_pick_form_inherit" model="ir.ui.view">
        <field name="name">panworld.stock.picking.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <button name="action_picking_move_tree" position="after">
                <button
                    class="oe_stat_button"
                    name="action_view_landed_cost"
                    type="object"
                    icon="fa-dollar"
                    groups="account.group_account_manager"
                    invisible="landed_cost_count == 0">
                    <field
                        string="Landed Cost"
                        name="landed_cost_count"
                        widget="statinfo"
                    />
                </button>
            </button>
            <field name="rma_done" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="origin" position="after">
                <field name="total_demand_qty" />
<!--                <field name="total_reserved_qty" />-->
                <field name="total_counted_qty" />
                <field name="total_done_qty" />
            </field>
            <xpath expr="//field[@name='carrier_tracking_ref']" position="after">
                <field name="weight" string="Total Weight" />
                <field name="grn_tracking_number_id" invisible="1"/>
            </xpath>
        </field>
    </record>
    <record id="delievry_stock_pick_form_inherit" model="ir.ui.view">
        <field name="name">delivery.panworld.stock.picking.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock_delivery.view_picking_withcarrier_out_form" />
        <field name="arch" type="xml">
            <field name="carrier_id" position="after">
                <field name="picking_sequence_code" invisible='1' />
            </field>
            <label for="carrier_tracking_ref" position="attributes">
                <attribute name="invisible">picking_sequence_code in ('SHIP','IN')</attribute>
            </label>
            <xpath expr="//div[@name='tracking']" position="attributes">
                <attribute name="invisible">picking_sequence_code in ('SHIP','IN')</attribute>
            </xpath>
            <field name="carrier_id" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="string">Shipper</attribute>
                <attribute name="index">True</attribute>
                <attribute
                    name="context"
                >{'from_stock_picking':True, 'partner_id': partner_id}</attribute>
            </field>
            <field name="picking_type_id" position="attributes">
                <attribute
                    name="context"
                >{'is_action_multi_grn': context.get('is_action_multi_grn')}</attribute>
            </field>
            <field name="location_dest_id" position="after">
                <field name="carrier_id" position="move" />
                <!-- AWB for GRN -->
                <field
                    name="carrier_tracking_ref"
                    string="Tracking(AWB)"
                    invisible="picking_sequence_code == 'SHIP'"
                />
                <!-- AWB for SHIPPER -->
                <field
                    name="carrier_tracking_ref"
                    string="SHP Tracking(AWB)"
                    invisible="picking_sequence_code != 'SHIP'"
                />
                <field
                    name="grn_tracking"
                    string="Tracking(AWB)"
                    invisible="picking_sequence_code != 'SHIP'"
                />
            </field>
        </field>
    </record>
    <record id="action_multi_grn" model="ir.actions.act_window">
        <field name="name">GRN - Via Shipper</field>
        <field name="res_model">stock.picking</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'is_action_multi_grn': True}</field>
    </record>
        <record id="panworld_vpicktree_inherit_bill_shipping_fields" model="ir.ui.view">
        <field name="name">vpicktree.inherit.add.bill.shipping.fileds</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="before">
                <field name="grn_tracking_number_id" optional="show"/>
            </xpath>

        </field>
    </record>

    <record id="view_picking_internal_search_panworld_landed_cost" model="ir.ui.view">
        <field name="name">stock.picking.search.panworld.landed.cost</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <field name="picking_type_id" position="after">
                <field name="grn_tracking_number_id"/>
            </field>
        </field>
    </record>
    <menuitem
        id="menu_multi_grn"
        name="GRN - Via Shipper"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_multi_grn"
        groups="stock.group_stock_manager,stock.group_stock_user"
    />
</odoo>
