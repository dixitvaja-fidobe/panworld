        <field name="prefix">LCO%(y)s%(month)s</field>
    </record>
    <function name="write" model="ir.model.data">
        <function name="search" model="ir.model.data">
            <value
                eval="[('name','=','seq_stock_landed_costs'),('module','=','stock_landed_costs')]"
            />
        </function>
        <value eval=" {'noupdate': True} " />
    </function>
</odoo>
