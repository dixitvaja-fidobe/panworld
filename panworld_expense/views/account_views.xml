<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited account move Form -->
    <record id="view_move_form_inherit_panworld_expense" model="ir.ui.view">
        <field name="name">view.account.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="expense_due_date" invisible="move_type != 'entry'"/>
                <field name="description" invisible="move_type != 'entry'"/>
            </xpath>
        </field>
    </record>
</odoo>
