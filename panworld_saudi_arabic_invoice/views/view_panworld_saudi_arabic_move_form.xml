<odoo>
    <data>
        <record id="view_panworld_saudi_arabic_form" model="ir.ui.view">
            <field name="name">account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <field name="invoice_date" position="after">
                    <field name="l10n_sa_show_delivery_date" invisible="1"/>
                    <field name="l10n_sa_delivery_date"
                           invisible="l10n_sa_show_delivery_date == False"
                           required="l10n_sa_show_delivery_date == True"/>
                </field>
                <field name="source_id" position="after">
                    <field name="in_supply_type" string="Supply Type"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
