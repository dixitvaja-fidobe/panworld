<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="arabic_english_invoice_panworld">
        <t t-call="panworld_saudi_arabic_invoice.external_layout_custom_arabic">
            <!-- Removed redefinition of o to avoid KeyError. Keep original o from outer context. -->
            <t t-set="forced_vat" t-value="o.fiscal_position_id.foreign_vat"/>
            <t t-set="o_sec" t-value="o.with_context(lang='ar_001')"/>
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&amp;family=Roboto:wght@200;500&amp;display=swap');
                .page {
                    position: relative !important;
                    margin-top: 0 !important;
                }
                
                h2 {
                    font-family: 'Roboto', 'Amiri', serif;
                    font-weight: 700;
                }
                
                .table {
                    border-collapse: collapse;
                    width: 100%;
                    margin-bottom: 1rem;
                    color: #212529;
                }
                
                .table th, .table td {
<!--                    padding: 0.75rem;-->
                    vertical-align: middle;
                    border-top: 1px solid #dee2e6;
                }
                
                .table thead th {
                    vertical-align: bottom;
                    border-bottom: 2px solid #dee2e6;
                    background-color: #f8f9fa;
                    color: #495057;
                    font-weight: bold;
                }
                
                .table-bordered {
                    border: 1px solid #dee2e6;
                }
                
                .table-bordered th, .table-bordered td {
                    border: 1px solid #dee2e6;
                }
                
                .o_main_table th {
                    text-transform: uppercase;
<!--                    font-size: 0.85rem;-->
<!--                    letter-spacing: 0.05em;-->
                }
                
                .invoice_tbody td {
<!--                    font-size: 0.9rem;-->
                }
                
                /* Ensure article content doesn't overlap with header */
                .article {
                    position: relative !important;
                    top: auto !important;
                    margin-top: 0 !important;
                }
            </style>
            <div class="page" style="margin-top: 80px;">
                <!-- Customer Address Section -->
                <div class="row" style="margin-top: 10px; margin-bottom: 20px;">
                    <div class="col-6 text-left">
                        <address t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}' style="text-align: left"/>
                        <div t-if="o.partner_id.vat">
                            <span>VAT:</span>
                        <span t-field="o.partner_id.vat"/>
                        </div>
                        <div t-if="o.partner_id.crn_number">
                            <span>CR:</span>
                        <span t-field="o.partner_id.crn_number"/>
                        </div>
                    </div>
                    <div class="col-6 text-right" style="direction: rtl;">
                        <div t-if="o_sec.partner_id.address_arabic">
                            <span t-esc="o_sec.partner_id.address_arabic" />
                        </div>
                        <div t-if="o_sec.partner_id.add_line_1_ar">
                            <span t-esc="o_sec.partner_id.add_line_1_ar" />
                        </div>
                        <div t-if="o_sec.partner_id.add_line_2_ar">
                            <span t-esc="o_sec.partner_id.add_line_2_ar" />
                        </div>
                        <div t-if="o_sec.partner_id.vat">
                            <span>VAT:</span>
                            <span t-field="o_sec.partner_id.vat"/>
                        </div>
                        <div t-if="o_sec.partner_id.crn_number">
                            <span>CR:</span>
                            <span t-field="o_sec.partner_id.crn_number"/>
                        </div>
                    </div>
                </div>
            <t>
                <p>
                    <img t-if="o.l10n_sa_qr_code_str" style="height: 130px;width: 130px;" t-att-src="'data:image/png;base64,' + o.generate_qr_code(o.l10n_sa_qr_code_str)" alt="QR Code" class="img-fluid"/>
                </p>
            </t>
            <t t-if="o.move_type == 'out_invoice' and o.state == 'posted' and o.journal_id.code !='SMP'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Tax Invoice</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">فاتورة ضريبية</h2>
            </t>
            <t t-if="o.move_type == 'out_invoice' and o.state == 'posted' and o.journal_id.code =='SMP'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Sample Invoice</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">عينة الفاتورة</h2>
            </t>
            <t t-if="o.move_type == 'out_invoice' and o.state == 'draft'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Draft Invoice</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">مسودة فاتورة</h2>
            </t>
            <t t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Cancelled Invoice</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">فاتورة ملغاة</h2>
            </t>
            <t t-if="o.move_type == 'out_refund'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Credit Note</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">إشعار خصم</h2>
            </t>
            <t t-if="o.move_type == 'in_refund'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Vendor Credit Note</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">إشعار خصم المورد</h2>
            </t>
            <t t-if="o.move_type == 'in_invoice'">
                <h2 class="text-center" style="color: black !important; margin-top: 20px;">Vendor Bill</h2>
                <h2 class="text-center" style="color: black !important; margin-bottom: 32px;">فاتورة المورد</h2>
            </t>
            <div id="informations" class="pb-3">
                <div class="row" t-if="o.name" name="invoice_number">
                    <div class="col-3">
                        <strong>Invoice Number:</strong>
                    </div>
                    <div class="col-6">
                        <span t-if="o.name != '/'" t-field="o.name"/>
                    </div>
                    <div class="col-3 text-right">
                        <strong>:رقم الفاتورة</strong>
                    </div>
                </div>
                    <div class="row" t-if="o.invoice_date" name="invoice_date">
                        <div class="col-3">
                            <strong>Invoice Date:</strong>
                        </div>
                        <div class="col-6">
                            <span t-field="o.invoice_date"/>
                        </div>
                        <div class="col-3 text-right">
                            <strong>:تاريخ الفاتورة</strong>
                        </div>
                    </div>
                    <div class="row"
                         t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'"
                         name="due_date">
                        <div class="col-3">
                            <strong>Due Date:</strong>
                        </div>
                        <div class="col-6">
                            <span t-field="o.invoice_date_due"/>
                        </div>
                        <div class="col-3 text-right">
                            <strong>:تاريخ الاستحقاق</strong>
                        </div>
                    </div>
                    <div class="row" t-if="o.ref" name="reference">
                        <div class="col-3">
                            <strong>Reference No.:</strong>
                        </div>
                        <div class="col-6">
                            <span t-field="o.ref"/>
                        </div>
                        <div class="col-3 text-right">
                            <strong>:رقم المرجع</strong>
                        </div>
                    </div>
                    <div class="row" t-if="o.tracking_ref" name="tracking_ref">
                        <div class="col-3">
                            <strong>PO Reference:</strong>
                        </div>
                        <div class="col-6">
                            <span t-field="o.tracking_ref"/>
                        </div>
                        <div class="col-3 text-right">
                            <strong>:رقم المرجع</strong>
                        </div>
                    </div>
                    <div class="row" t-if="o.invoice_payment_term_id" name="payment_term">
                        <div class="col-3">
                            <strong>Payment Term:</strong>
                        </div>
                        <div class="col-6">
                            <span t-field="o.invoice_payment_term_id.name"/>
                        </div>
                        <div class="col-3 text-right">
                            <strong>:مصطلح الدفع</strong>
                        </div>
                    </div>
                </div>


                <t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
                <table class="table table-sm o_main_table table-bordered" name="invoice_line_table">
                    <thead>
                        <tr>
                            <t t-set="colspan" t-value="7"/>
                            <th name="th_sequence" class="text-center" style="width: 5%;">
                                <span>
                                    Customer
                                </span>
                                <br/>
                                <span>
                                    PO Seq
                                </span>
                                <br/>
                                <span>
                                    الرقم التسلسلي
                                </span>
                            </th>
                            <th name="th_description" style="width: 45%;" class="text-left">
                                <span>
                                    Description
                                </span>
                                <br/>
                                <span>
                                    الوصف
                                </span>
                            </th>
                            <th name="th_source" class="d-none text-left" t-if="0">
                                <span>
                                    Source Document
                                </span>
                                <br/>
                                <span>
                                    المستند المصدر
                                </span>
                            </th>
                            <th name="th_quantity" class="text-right">
                                <span>
                                    Qty
                                </span>
                                <br/>
                                <span>
                                    الكمية
                                </span>
                            </th>
                            <th name="th_priceunit"
                                class="text-right" style="width: 5%;">
                                <span>
                                    Unit price
                                </span>
                                <br/>
                                <span>
                                    سعر الوحدة
                                </span>
                            </th>
                            <th name="th_price_unit" t-if="display_discount"
                                class="text-right">
                                <span>
                                    Disc.%
                                </span>
                                <br/>
                                <span>
                                    خصم %
                                </span>
                                <t t-set="colspan" t-value="colspan+1"/>
                            </th>
                            <th name="th_taxes" style="width: 5%;"
                                class="text-right">
                                <span>
                                    VAT
                                </span>
                                <br/>
                                <span>
                                    الضريبي
                                </span>
                            </th>
                            <th name="th_subtotal" class="text-right" style="width: 5%;">
                                <span>
                                    Amount
                                </span>
                                <br/>
                                <span>
                                    مبلغ
                                </span>
                            </th>
                            <th name="th_tax_amount"
                                class="text-right" style="width: 5%;">
                                <span>
                                    VAT Amount
                                </span>
                                <br/>
                                <span>
                                    السعر الضريبي
                                </span>
                            </th>
                            <th name="th_total" class="text-right" style="width: 5%;">
                                <span>
                                    Total Price
                                </span>
                                <br/>
                                <span>
                                    السعر الاجمالي
                                </span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-set="lines"
                           t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                        <t t-foreach="lines" t-as="line">
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                                groups="account.group_show_line_subtotals_tax_excluded"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                                groups="account.group_show_line_subtotals_tax_included"/>
                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="line.display_type not in ('line_section', 'line_note')" name="account_invoice_line_accountable">
                                    <td class="text-center">
                                        <span t-esc="line_index + 1"/>
                                    </td>
                                    <td name="account_invoice_line_name">
                                        <t t-if="line.product_id">
                                            <t t-set="arabic_name" t-value="line.with_context(lang='ar_001').product_id.display_name"/>
                                            <t t-set="english_name" t-value="line.with_context(lang='en_US').product_id.display_name"/>

                                            <span t-field="line.product_id.display_name"
                                                t-options="{'widget': 'text'}"/>

                                            <t t-if="arabic_name != english_name">
                                                <br/>
                                                <span t-field="line.with_context(lang='ar_001').product_id.name"
                                                    style="text-align: right; direction: rtl; display: block;"
                                                    t-options="{'widget': 'text'}"/>
                                            </t>

                                            <t t-if="line.name != english_name and line.name != arabic_name">
                                                <br/>
                                                <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.quantity"/>
<!--                                        <span t-field="line.product_uom_id" groups="uom.group_uom"/>-->
                                    </td>
                                    <td class="text-right">
                                        <span class="text-nowrap" t-field="line.price_unit"/>
                                    </td>
                                    <td t-if="display_discount" class="text-right">
                                        <span class="text-nowrap" t-field="line.discount"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="', '.join(map(lambda x: (str(x.amount) + '%'), line.tax_ids))" id="line_tax_ids"/>
                                    </td>
                                    <td class="text-right o_price_total">
                                        <span class="text-nowrap" t-field="line.price_subtotal"/>
                                    </td>
                                    <td class="text-right">
                                        <span class="text-nowrap" t-field="line.l10n_gcc_invoice_tax_amount"/>
                                    </td>
                                    <td class="text-right o_price_total">
                                        <span class="text-nowrap" t-field="line.price_total"/>
                                    </td>
                                </t>
                                <t t-if="line.display_type == 'line_section'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-if="line.display_type == 'line_note'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>

                            <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                                <tr class="is-subtotal text-right">
                                    <td colspan="99">
                                        <strong class="mr16" style="display: inline-block">Subtotal/الإجمالي الفرعي</strong>
                                        <span
                                                t-out="current_subtotal"
                                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                        />
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>
                <h6>
                    <strong>Amount in Words :</strong>
                    <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                </h6>
                <div class="clearfix pt-4 pb-3">
                    <div id="total" class="row">
                        <div class="col-6">
                            <table class="table table-sm" style="page-break-inside: avoid;">
                                <tr class="border-black o_subtotal">
                                    <td>
                                        <strong>
                                            Subtotal
                                            /
                                            الإجمالي الفرعي
                                        </strong>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="o.amount_untaxed"/>
                                    </td>
                                </tr>
                                <t t-if="o.tax_totals">
                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                            <tr class="border-black">
                                                <td>
                                                    <span class="text-nowrap" t-out="tax_group['group_name']"/>
                                                </td>
                                                <td class="text-right">
                                                    <span class="text-nowrap"
                                                          t-out="tax_group['tax_amount_currency']"
                                                          t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </t>
                                <tr class="border-black o_total">
                                    <td>
                                        <strong>
                                            Total
                                            /
                                            المجموع
                                        </strong>
                                    </td>
                                    <td class="text-right">
                                        <span class="text-nowrap" t-field="o.amount_total"/>
                                    </td>
                                </tr>
                                <tr class="border-black o_total">
                                    <td>
                                        <strong>
                                            Total Units
                                        </strong>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="sum(o.invoice_line_ids.mapped('quantity'))" t-options='{"widget": "float", "precision": 0}'/>
                                    </td>
                                </tr>

                                <t t-if="print_with_payments">
                                    <t t-if="o.payment_state != 'invoicing_legacy'">
                                        <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                            <tr class="border-black o_total">
                                                <td>
                                                    <i class="row">
                                                        <div class="col-7 oe_form_field oe_payment_label">
                                                            Paid on/دفعت في:
                                                        </div>
                                                        <div class="col-5 pl-0 oe_form_field oe_payment_label">
                                                            <t t-out="payment_vals['date']"/>
                                                        </div>
                                                    </i>
                                                </td>
                                                <td class="text-right">
                                                    <span t-out="payment_vals['amount']"
                                                          t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="len(payments_vals) > 0">
                                            <tr class="border-black">
                                                <td>
                                                    <strong>
                                                        Amount Due
                                                        /
                                                        المبلغ المستحق
                                                    </strong>
                                                </td>
                                                <td class="text-right">
                                                    <span t-field="o.amount_residual"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </t>
                            </table>
                        </div>
                    </div>
                </div>

                <!--<p t-if="o.move_type in ('out_invoice', 'in_refund') and o.payment_reference" name="payment_communication">
                    <div class="row">
                        <div class="col-6 text-left">
                            Payment Reference :
                            <b>
                                <span t-field="o.payment_reference"/>
                            </b>
                        </div>
                        <div class="col-6 text-right">
                            <p>
                                <b>
                                    <span t-field="o.payment_reference"/> :
                                </b>رقم إشارة الدفعة
                            </p>
                        </div>
                    </div>
                </p>-->
                <p t-if="o.narration" name="comment">
                    <div class="row">
                        <div class="col-12 text-right">
                            <span t-field="o_sec.narration"/>
                        </div>
                    </div>
                </p>
                <p t-if="o.fiscal_position_id.note" name="note">
                    <div class="row">
                        <div class="col-6 text-left">
                            <span t-field="o.fiscal_position_id.note"/>
                        </div>
                        <div class="col-6 text-right">
                            <span t-field="o_sec.fiscal_position_id.note"/>
                        </div>
                    </div>
                </p>
                <p t-if="o.invoice_incoterm_id" name="incoterm">
                    <div class="row">
                        <div class="col-6 text-left">
                            <strong>Incoterm:
                            </strong>
                            <span
                                    t-field="o.invoice_incoterm_id.code"/>
                            -
                            <span
                                    t-field="o.invoice_incoterm_id.name"/>
                        </div>
                        <div class="col-6 text-right">
                            <strong>شرط تجاري:
                            </strong>
                            <span
                                    t-field="o_sec.invoice_incoterm_id.code"/>
                            -
                            <span
                                    t-field="o_sec.invoice_incoterm_id.name"/>
                        </div>
                    </div>
                </p>

            </div>
        </t>
    </template>
    <template id="report_invoice_panworld_saudi">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="panworld_saudi_arabic_invoice.arabic_english_invoice_panworld" t-lang="lang"/>
            </t>
        </t>
    </template>
</odoo>
