<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_report_layout_sa_invoice">
        <div class="header">
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&amp;family=Inter:wght@400;600;700&amp;display=swap');
                .header {
                    font-family: 'Inter', 'Amiri', sans-serif;
                }
            </style>
            <!-- Logo row -->
            <div class="row mb-1">
                <div class="col-12 text-left">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo" style="max-height: 120px; max-width: 350px;" />
                </div>
            </div>
        </div>

        <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o._context.get('lang')">
            <t t-raw="0" />
        </div>

        <div class="footer" style="font-size: 0.75rem; font-family: 'Inter', sans-serif; border-top: 1px solid #eee; padding-top: 8px;">
            <div style="width: 100%; display: table;">
                <div style="display: table-cell; text-align: left; color: #666; vertical-align: middle;">
                    <div class="text-start" style="width: 100%; padding: 5px 0px;">
                        <div t-field="company.report_footer"
                             style="font-size: 11px !important; color: #666666; line-height: 1.2; display: inline-block;"/>
                    </div>
                </div>
                <div style="display: table-cell; text-align: right; color: #999; font-size: 0.7rem; vertical-align: middle;">
                    Page: <span class="page" /> / <span class="topage" />
                </div>
            </div>
        </div>
    </template>

    <template id="external_layout_sa_invoice">
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc.with_context(lang='ar_001')" />
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo().with_context(lang='ar_001')" />
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company.with_context(lang='ar_001')" />
        </t>
        <t t-call="panworld_saudi_arabic_invoice.external_report_layout_sa_invoice">
            <t t-raw="0" />
        </t>
    </template>

    <template id="report_sa_invoice_template">
        <t t-call="panworld_saudi_arabic_invoice.external_layout_sa_invoice">
            <t t-set="company" t-value="o.company_id"/>
            <t t-set="o_sec" t-value="o.with_context(lang='ar_001')"/>
            
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&amp;family=Inter:wght@400;600;700&amp;display=swap');
                
                .page {
                    font-family: 'Inter', 'Amiri', sans-serif;
                    color: #1a1a1b;
                    line-height: 1.3;
                    font-size: 15px;
                }
                .table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-top: 15px;
                }
                .table th {
                    background-color: #f8f9fa;
                    color: #111;
                    font-weight: 700;
                    border: 1px solid #e0e0e0;
                    padding: 6px 4px;
                    font-size: 13px;
                    vertical-align: middle;
                    overflow: hidden;
                    text-align: center;
                }
                .table td {
                    border: 1px solid #e0e0e0;
                    padding: 5px 4px;
                    font-size: 13px;
                    vertical-align: middle;
                }
                .label-title {
                    font-weight: 700;
                    color: #333;
                    font-size: 14px;
                    margin-bottom: 4px;
                }
                .company-details {
                    margin-bottom: 20px;
                }
            </style>

            <div class="page" style="padding-top: 0;">
                <!-- Company Details Section - Back in body to only show on first page -->
                <div class="row company-details" style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    <div class="col-6 text-left">
                        <t t-set="company_en" t-value="company.sudo().with_context(lang='en_US')" />
                        <div style="font-size: 15px; font-weight: 700; color: #111;"><span t-field="company_en.name" /></div>
                        <div style="font-size: 15px; color: #333;"><span t-field="company_en.street" /></div>
                        <div t-if="company_en.city" style="font-size: 15px; color: #333;">
                            <span t-field="company_en.city" />, <span t-field="company_en.state_id.name" /> <span t-field="company_en.zip" />
                        </div>
                        <div t-if="company_en.partner_id.vat" style="font-size: 15px; color: #333;">VAT: <span t-field="company_en.partner_id.vat"/></div>
                        <div t-if="company_en.crn_number" style="font-size: 15px; color: #333;">CR: <span t-field="company_en.crn_number"/></div>
                    </div>
                    <div class="col-6 text-right" style="direction: rtl;">
                        <t t-set="company_ar" t-value="company.sudo().with_context(lang='ar_001')" />
                        <t t-set="has_company_ar_address" t-value="company.address_arabic or company.add_line_1_ar"/>
                        <div t-if="company.address_arabic" style="font-size: 15px; font-weight: 700; color: #111;"><span t-esc="company.address_arabic" /></div>
                        <div t-if="company.add_line_1_ar" style="font-size: 15px; color: #333;">
                            <span t-esc="company.add_line_1_ar" />
                        </div>
                        <div t-if="company.add_line_2_ar" style="font-size: 15px; color: #333;">
                            <span t-esc="company.add_line_2_ar" />
                        </div>
                        <div t-if="company.add_line_3_ar" style="font-size: 15px; color: #333;">
                            <span t-esc="company.add_line_3_ar" />
                        </div>
                        <div t-if="company.add_line_4_ar" style="font-size: 15px; color: #333;">
                            <span t-esc="company.add_line_4_ar" />
                        </div>
                        <t t-if="has_company_ar_address">
                            <div t-if="company.partner_id.vat" style="font-size: 15px; color: #333;">
                                الرقم الضريبي: <span t-esc="company.to_arabic_text(company.partner_id.vat)"/>
                            </div>
                            <div t-if="company.crn_number" style="font-size: 15px; color: #333;">
                                سجل تجاري: <span t-esc="company.to_arabic_text(company.crn_number)"/>
                            </div>
                        </t>
                    </div>
                </div>
            
            <!-- Customer Address Section - Simplified to match company pattern -->
                <div class="row" style="margin-bottom: 20px;">
                    <div class="col-6 text-left">
                        <t t-set="partner_en" t-value="o.partner_id.with_context(lang='en_US')"/>
                        <div style="font-size: 15px; font-weight: 700; color: #111;"><span t-field="partner_en.name"/></div>
                        <div style="font-size: 15px; color: #333;">
                            <div t-if="partner_en.street"><span t-field="partner_en.street"/></div>
                            <div t-if="partner_en.street2"><span t-field="partner_en.street2"/></div>
                            <div t-if="partner_en.city">
                                <span t-field="partner_en.city"/><t t-if="partner_en.state_id">, <span t-field="partner_en.state_id.name"/></t> <t t-if="partner_en.zip"><span t-field="partner_en.zip"/></t>
                            </div>
                            <div t-if="partner_en.country_id"><span t-field="partner_en.country_id.name"/></div>
                        </div>
                        <div t-if="partner_en.vat" style="font-size: 15px; color: #333;">
                            VAT: <span t-field="partner_en.vat"/>
                        </div>
                        <div t-if="partner_en.crn_number" style="font-size: 15px; color: #333;">
                            CR: <span t-field="partner_en.crn_number"/>
                        </div>
                    </div>
                    <div class="col-6 text-right" style="direction: rtl;">
                        <t t-set="partner_ar" t-value="o.partner_id.with_context(lang='ar_001')"/>
                        <t t-if="partner_ar.address_arabic or partner_ar.add_line_1_ar">
                            <div style="font-size: 15px; font-weight: 700; color: #111;">
                                <span t-esc="partner_ar.address_arabic"/>
                            </div>
                            <div t-if="partner_ar.add_line_1_ar" style="font-size: 15px; color: #333;">
                                <span t-esc="partner_ar.add_line_1_ar"/>
                            </div>
                            <div t-if="partner_ar.add_line_2_ar" style="font-size: 15px; color: #333;">
                                <span t-esc="partner_ar.add_line_2_ar"/>
                            </div>
                            <div t-if="partner_ar.add_line_3_ar" style="font-size: 15px; color: #333;">
                                <span t-esc="partner_ar.add_line_3_ar"/>
                            </div>
                            <div t-if="partner_ar.add_line_4_ar" style="font-size: 15px; color: #333;">
                                <span t-esc="partner_ar.add_line_4_ar"/>
                            </div>
                            <div t-if="partner_ar.vat" style="font-size: 15px; color: #333;">
                                الرقم الضريبي: <span t-esc="o.company_id.to_arabic_text(partner_ar.vat)"/>
                            </div>
                            <div t-if="partner_ar.crn_number" style="font-size: 15px; color: #333;">
                                سجل تجاري: <span t-esc="o.company_id.to_arabic_text(partner_ar.crn_number)"/>
                            </div>
                        </t>
                    </div>
                </div>

                <div class="row mb-1">
                    <div class="col-12 text-left">
                        <img t-if="o.l10n_sa_qr_code_str" style="height: 120px; width: 120px;" t-att-src="'data:image/png;base64,' + o.generate_qr_code(o.l10n_sa_qr_code_str)" alt="QR Code" class="img-fluid"/>
                    </div>
                </div>

                <!-- Tax Invoice Heading - Moved under QR code -->
                <div class="row" style="margin-bottom: 15px; margin-top: 5px;">
                    <div class="col-12 text-center">
                        <h3 style="margin: 0; font-weight: 700; color: #111; font-size: 22px;">
                            <t t-if="o.move_type == 'out_invoice' and o.state == 'posted' and o.journal_id.code !='SMP'">TAX INVOICE / فاتورة ضريبية</t>
                            <t t-if="o.move_type == 'out_invoice' and o.state == 'posted' and o.journal_id.code =='SMP'">SAMPLE INVOICE / نموذج الفاتورة</t>
                            <t t-if="o.move_type == 'out_invoice' and o.state == 'draft'">DRAFT INVOICE / مسودة فاتورة</t>
                            <t t-if="o.move_type == 'out_refund'">CREDIT NOTE / إشعار خصم</t>
                            <t t-if="o.move_type == 'in_refund'">VENDOR CREDIT NOTE / إשعار خصم المورد</t>
                            <t t-if="o.move_type == 'in_invoice'">VENDOR BILL / فاتورة المورد</t>
                        </h3>
                    </div>
                </div>
                <div id="informations" style="font-size: 15px; margin-bottom: 25px; line-height: 1.5;">
                    <div class="row" t-if="o.name and o.name != '/'" name="invoice_number">
                        <div class="col-4"><strong>Invoice Number:</strong></div>
                        <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.name"/></div>
                        <div class="col-4 text-right" style="direction: rtl;"><strong>رقم الفاتورة:</strong></div>
                    </div>
            <div class="row" t-if="o.invoice_date" name="invoice_date">
                <div class="col-4"><strong>Invoice Date:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.invoice_date"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>تاريخ الفاتورة:</strong></div>
            </div>
            <div class="row" t-if="o.invoice_date_due" name="due_date">
                <div class="col-4"><strong>Due Date:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.invoice_date_due"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>تاريخ الاستحقاق:</strong></div>
            </div>
            <div class="row" t-if="o.ref" name="reference">
                <div class="col-4"><strong>Reference No.:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.ref"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>رقم المرجع:</strong></div>
            </div>
            <div class="row" t-if="o.tracking_ref" name="po_reference">
                <div class="col-4"><strong>PO Reference:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.tracking_ref"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>رقم المرجع:</strong></div>
            </div>
            <div class="row" t-if="o.invoice_payment_term_id" name="payment_term">
                <div class="col-4"><strong>Payment Term:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.invoice_payment_term_id.name"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>مصطلح الدفع:</strong></div>
            </div>
            <div class="row" t-if="o.currency_id" name="invoice_currency">
                <div class="col-4"><strong>Invoice Currency:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.currency_id.name"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>عملة الفاتورة:</strong></div>
            </div>
            <div class="row" t-if="o.in_supply_type" name="in_supply_type">
                <div class="col-4"><strong>Supply Type:</strong></div>
                <div class="col-4 text-left" style="padding-left: 40px;"><span t-field="o.in_supply_type"/></div>
                <div class="col-4 text-right" style="direction: rtl;"><strong>نوع العرض:</strong></div>
            </div>
                </div>

                <table class="table table-sm mt-4" name="invoice_line_table">
                    <thead>
                        <tr style="text-transform: uppercase;">
                            <th style="width: 8%; text-align: center; vertical-align: middle;">
                                <span>CUSTOMER</span><br/>
                                <span>PO SEQ</span><br/>
                                <span dir="rtl">الرقم التسلسلي</span>
                            </th>
                            <th style="width: 30%; vertical-align: middle; text-align: center;">
                                <span>DESCRIPTION</span><br/>
                                <span dir="rtl">الوصف</span>
                            </th>
                            <th class="text-center" style="width: 8%; vertical-align: middle; text-align: center;">
                                <span>QTY</span><br/>
                                <span dir="rtl">الكمية</span>
                            </th>
                            <th class="text-center" style="width: 10%; vertical-align: middle; text-align: center;">
                                <span>UNIT PRICE</span><br/>
                                <span dir="rtl">سعر الوحدة</span>
                            </th>
                            <th class="text-center" style="width: 7%; vertical-align: middle; text-align: center;">
                                <span>VAT</span><br/>
                                <span dir="rtl">الضريبي</span>
                            </th>
                            <th class="text-center" style="width: 13%; vertical-align: middle; text-align: center;">
                                <span>AMOUNT</span><br/>
                                <span dir="rtl">مبلغ</span>
                            </th>
                            <th class="text-center" style="width: 10%; vertical-align: middle; text-align: center;">
                                <span>VAT AMOUNT</span><br/>
                                <span dir="rtl">السعر الضريبي</span>
                            </th>
                            <th class="text-center" style="width: 14%; vertical-align: middle; text-align: center;">
                                <span>TOTAL PRICE</span><br/>
                                <span dir="rtl">السعر الاجمالي</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: l.sequence)"/>
                        <t t-foreach="lines" t-as="line">
                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="line.display_type not in ('line_section', 'line_note')" name="account_invoice_line_accountable">
                                    <td class="text-center"><span t-esc="line_index + 1"/></td>
                                    <td>
                                        <span t-field="line.name"/>
                                        <t t-if="line.product_id">
                                            <t t-set="p_ar" t-value="line.product_id.with_context(lang='ar_001')"/>
                                            <div t-if="p_ar.display_name != line.product_id.display_name" style="direction: rtl; color: #666; font-size: 14px; margin-top: 4px;">
                                                <span t-field="p_ar.display_name"/>
                                            </div>
                                        </t>
                                    </td>
                                    <td class="text-end" style="text-align: right;">
                                        <span t-field="line.quantity" t-options='{"widget": "float", "precision": 0}'/>
                                    </td>
                                    <td class="text-end" style="text-align: right;">
                                        <span t-field="line.price_unit" t-options='{"widget": "float", "precision": 3}'/>
                                    </td>
                                    <td class="text-end" style="text-align: right;">
                                        <t t-if="line.tax_ids">
                                            <span t-esc="'%.1f' % line.tax_ids[0].amount"/>%
                                        </t>
                                        <t t-else="">0.0%</t>
                                    </td>
                                    <td class="text-end" style="text-align: right;">
                                        <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                    </td>
                                    <td class="text-end" style="text-align: right;">
                                        <span t-esc="'{:,.2f}'.format(line.l10n_gcc_invoice_tax_amount)"/>
                                    </td>
                                    <td class="text-end o_price_total" style="text-align: right;">
                                        <span t-esc="'{:,.2f}'.format(line.price_total)"/>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                        <tr t-if="not lines">
                            <td colspan="8" class="text-center">No products found for this invoice.</td>
                        </tr>
                    </tbody>
                </table>

                <div class="row mt-4" style="page-break-inside: avoid;">
                    <div class="col-7"></div>
                    <div class="col-5">
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Subtotal / الإجمالي الفرعي</strong></td>
                                <td class="text-end" style="text-align: right;">
                                    SAR <span t-esc="'{:,.2f}'.format(o.amount_untaxed)"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>VAT / الضريبة</strong></td>
                                <td class="text-end" style="text-align: right;">
                                    SAR <span t-esc="'{:,.2f}'.format(o.amount_tax)"/>
                                </td>
                            </tr>
                            <tr class="border-black">
                                <td><strong>Total / الإجمالي</strong></td>
                                <td class="text-end" style="text-align: right;">
                                    SAR <span t-esc="'{:,.2f}'.format(o.amount_total)"/>
                                </td>
                            </tr>
                            <tr class="border-black o_total">
                                <td>
                                    <strong>
                                        Total Units / إجمالي الوحدات
                                    </strong>
                                </td>
                                <td class="text-end" style="text-align: right;">
                                    <span t-esc="sum(o.invoice_line_ids.mapped('quantity'))"
                                          t-options='{"widget": "float", "precision": 0}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Amount in Words Section - Redesigned under totals -->
                <div class="row mt-3" style="page-break-inside: avoid;">
                    <div class="col-6" style="padding: 5px 0;">
                        <strong>Amount in Words:</strong> <br/>
                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                    </div>
                    <div class="col-6" style="padding: 5px 0; direction: rtl; text-align: right;">
                        <strong>المبلغ بالكلمات:</strong> <br/>
                        <span t-esc="o.currency_id.with_context(lang='ar_001').amount_to_text(o.amount_total)"/>
                    </div>
                </div>

                <!-- Summary Section - EN Left / AR Right -->
                <div t-if="not (is_html_empty(partner_en.summary) and is_html_empty(partner_ar.summary_ar))" class="mt-4"
                     style="page-break-inside: avoid;">
                    <div class="row">
                        <div t-if="not is_html_empty(partner_en.summary)" class="col-6">
                                <strong style="text-decoration: underline;">Summary of the Items</strong>
                                <div class="mt-2" style="font-size: 13px; color: #555;">
                                    <t t-if="partner_en.summary">
                                        <span t-esc="partner_en.summary"/>
                                    </t>
                                </div>
                        </div>
                        <div t-if="not is_html_empty(partner_ar.summary_ar)" class="col-6 text-right" style="direction: rtl;">
                                <strong style="text-decoration: underline;">ملخص العناصر</strong>
                                <div class="mt-2" style="font-size: 13px; color: #555;">
                                    <t t-if="partner_ar.summary_ar">
                                        <span t-esc="partner_ar.summary_ar"/>
                                    </t>
                                </div>
                        </div>
                    </div>
                </div>

                <!-- Terms and Conditions Section - EN Left / AR Right -->
                <div t-if="o.narration or not is_html_empty(o.company_id.payment_term_condition_ar)" class="mt-4" style="page-break-inside: avoid;">
                    <div class="row">
                        <div class="col-6">
                            <t t-if="o.narration">
                                <strong style="text-decoration: underline;">Terms &amp; Conditions</strong>
                                <div class="mt-2" style="font-size: 13px; color: #555;">
                                    <t t-if="partner_en.payment_term_condition">
                                        <span t-esc="partner_en.payment_term_condition"/>
                                    </t>
                                    <t t-else="">
                                    <span t-field="o.with_context(lang='en_US').narration"/>
                                    </t>
                                </div>
                            </t>
                        </div>
                        <div class="col-6 text-right" style="direction: rtl;">
                            <t t-if="not is_html_empty(o.company_id.payment_term_condition_ar)">
                                <strong style="text-decoration: underline;">الشروط والأحكام</strong>
                                <div class="mt-2" style="font-size: 13px; color: #555;">
                                    <t t-if="partner_ar.payment_term_condition_ar">
                                        <span t-esc="partner_ar.payment_term_condition_ar"/>
                                    </t>
                                    <t t-else="">
                                         <span t-field="o.company_id.payment_term_condition_ar"/>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Bank Details Section - EN Left / AR Right -->
                <div t-if="not is_html_empty(o.company_id.bank_details) or not is_html_empty(o.company_id.bank_details_ar)" class="mt-5" style="page-break-inside: avoid;">
                    <div class="row">
                        <div class="col-6">
                            <t t-if="not is_html_empty(o.company_id.bank_details)">
