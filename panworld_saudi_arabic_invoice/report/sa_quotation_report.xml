<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_sa_quotation_landscape" model="report.paperformat">
        <field name="name">SA Quotation Landscape Paperformat</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">35</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">30</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_sa_quotation" model="ir.actions.report">
        <field name="name">PDF Quote FOR KSA ONLY</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">panworld_saudi_arabic_invoice.report_sa_quotation</field>
        <field name="report_file">panworld_saudi_arabic_invoice.report_sa_quotation</field>
        <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name) or 'Order - %s' % (object.name))</field>
        <field name="binding_view_types">list,form</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="domain">[('company_id.currency_id.name', '=', 'SAR')]</field>
        <field name="paperformat_id" ref="paperformat_sa_quotation_landscape"/>
    </record>
</odoo>
